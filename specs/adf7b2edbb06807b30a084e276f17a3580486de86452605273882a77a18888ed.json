  {
    "function_v0": {
      "doc": "Aggregate multiple contract calls in a single tx, with affiliate fees\\ntaken either from the input token (before instructions) or from the\\noutput token (after instructions), per `fee_position`.\\n\\nReturns the user's actual output_token amount NET of any output-side fee.\\n\\nPermissionless: there is no allowlist of targets. The user signs a tx\\nthat contains the exact `instructions` vector being authorized; their\\nsignature *is* the authorization. The router does not custody funds and\\ncannot move tokens beyond what the user has signed for (directly or via\\nsource-account auth).",
      "name": "execute",
      "inputs": [
        {
          "doc": "",
          "name": "user",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "swap_id",
          "type_": {
            "bytes_n": {
              "n": 16
            }
          }
        },
        {
          "doc": "",
          "name": "input_token",
          "type_": "address"
        },
