  {
    "udt_struct_v0": {
      "doc": "NAV computation result.",
      "lib": "",
      "name": "NAVResult",
      "fields": [
        {
          "doc": "True when total_liabilities > total_assets (position is underwater)",
          "name": "is_underwater",
          "type_": "bool"
        },
        {
          "doc": "Number of positions evaluated",
          "name": "positions_count",
          "type_": "u32"
        },
        {
          "doc": "Timestamp of computation (ledger timestamp)",
          "name": "timestamp",
          "type_": "u64"
        },
        {
          "doc": "Total assets (positive positions) in USDC",
          "name": "total_assets",
          "type_": "i128"
        },
        {
          "doc": "Total liabilities (debt positions, as positive number) in USDC",
          "name": "total_liabilities",
          "type_": "i128"
        },
        {
          "doc": "Total NAV in USDC (6 decimals) = total_assets - total_liabilities",
          "name": "total_nav",
          "type_": "i128"
        }
      ]
    }
