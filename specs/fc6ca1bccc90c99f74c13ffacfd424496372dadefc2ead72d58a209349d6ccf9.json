  {
    "udt_struct_v0": {
      "doc": "Registered position in the registry (stored per-account).",
      "lib": "",
      "name": "PositionRecord",
      "fields": [
        {
          "doc": "Protocol adapter contract address \\xe2\\x80\\x94 **write-time snapshot**.\\nThis field captures the adapter address at the time `register_position` was called.\\nIt is NOT updated by `update_adapter`. After an atomic adapter replacement,\\n`get_positions` / `get_position` will return the old address here; off-chain tooling\\nshould resolve the current adapter via `get_adapter(protocol_id)` instead.\\nPhase 3 `compute_nav` is unaffected \\xe2\\x80\\x94 it always resolves via the live registry.",
          "name": "adapter",
          "type_": "address"
        },
        {
          "doc": "Whether this position is active",
          "name": "enabled",
          "type_": "bool"
        },
        {
          "doc": "Position identifier within the protocol",
          "name": "position_id",
          "type_": "symbol"
        },
        {
          "doc": "Protocol identifier (e.g., \"blend\", \"direct\")",
          "name": "protocol_id",
          "type_": "symbol"
        }
      ]
    }
  },
  {
    "udt_error_enum_v0": {
      "doc": "All error codes for PositionRegistry (16 error codes).",
      "lib": "",
      "name": "PositionError",
      "cases": [
        {
          "doc": "Contract not yet initialized",
          "name": "NotInitialized",
          "value": 1
        },
        {
          "doc": "Contract already initialized \\xe2\\x80\\x94 cannot re-initialize",
          "name": "AlreadyInitialized",
          "value": 2
        },
        {
          "doc": "Caller is not the admin",
          "name": "Unauthorized",
          "value": 3
        },
        {
          "doc": "No adapter registered for this protocol_id",
          "name": "AdapterNotFound",
          "value": 4
        },
        {
          "doc": "Adapter already registered for this protocol_id",
          "name": "AdapterAlreadyExists",
          "value": 5
        },
        {
          "doc": "Position not found for the given account/index",
          "name": "PositionNotFound",
          "value": 6
        },
        {
          "doc": "Position already exists for the given account + protocol + position_id",
          "name": "PositionAlreadyExists",
          "value": 7
        },
        {
          "doc": "OracleRegistry cross-contract call failed",
          "name": "OracleError",
          "value": 8
        },
        {
          "doc": "Adapter cross-contract call failed",
          "name": "AdapterCallFailed",
          "value": 9
        },
        {
          "doc": "Arithmetic overflow in NAV computation",
          "name": "MathOverflow",
          "value": 10
        },
        {
          "doc": "Invalid position_id or protocol_id argument",
          "name": "InvalidArgument",
          "value": 11
        },
        {
          "doc": "Maximum adapter limit reached",
          "name": "TooManyAdapters",
          "value": 13
        },
        {
          "doc": "Maximum positions per account limit reached",
          "name": "TooManyPositions",
          "value": 14
        },
        {
          "doc": "Cannot remove adapter \\xe2\\x80\\x94 positions still exist for this protocol",
          "name": "PositionsExistForAdapter",
          "value": 15
        },
        {
          "doc": "Contract does not exist at the given address",
          "name": "ContractNotFound",
          "value": 16
        },
        {
          "doc": "Adapter update not proposed or does not match pending update",
          "name": "AdapterUpdateNotPending",
          "value": 17
        }
      ]
    }
