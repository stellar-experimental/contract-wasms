  {
    "function_v0": {
      "doc": "Compute the NAV for an account.\\n\\nNOTE: This function is designed for off-chain simulation (simulateTransaction) only.\\nCalling it as a real on-chain transaction will exceed the 100M instruction budget for\\nrealistic adapter \\xc3\\x97 pool configurations. This is acceptable for NAV reporting use cases.\\n\\nAccount-agnostic: any address can be queried without prior registration.\\nReturns zero NAV for accounts with no positions \\xe2\\x80\\x94 NOT an error.\\n\\nPer-adapter error isolation: if one adapter panics or returns an error, the remaining\\nadapters are still queried and their results are included in the NAV.",
      "name": "compute_nav",
      "inputs": [
        {
          "doc": "",
          "name": "account",
          "type_": "address"
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": {
              "udt": {
                "name": "NAVResult"
              }
            },
            "error_type": {
              "udt": {
                "name": "PositionError"
              }
            }
          }
        }
      ]
    }
  },
