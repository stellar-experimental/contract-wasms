  {
    "function_v0": {
      "doc": "Compute NAV for a single specific adapter, identified by protocol_id.\\n\\nThis is the budget-safe alternative to `compute_nav()` when an adapter contains\\nmany pools. Instead of looping all adapters in one transaction, call this function\\nonce per adapter \\xe2\\x80\\x94 each call stays within the CPU budget.\\n\\nReturns the same NAVResult structure as `compute_nav()` but scoped to only the\\nspecified adapter's positions.\\n\\nErrors:\\n- NotInitialized if contract is not initialized\\n- AdapterNotFound if protocol_id is not registered\\n- AdapterError if the adapter call fails (propagated)",
      "name": "compute_nav_adapter",
      "inputs": [
        {
          "doc": "",
          "name": "account",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "protocol_id",
          "type_": "symbol"
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": {
              "udt": {
                "name": "NAVResult"
              }
            },
            "error_type": {
              "udt": {
                "name": "PositionError"
              }
            }
          }
        }
      ]
    }
  },
