  {
    "function_v0": {
      "doc": "Increases the deferred fee balance for a wallet.\\n\\nPurpose:\\nAllows a wallet to accumulate unpaid protocol fees in base fee units\\nfor later settlement.\\n\\nSecurity:\\n- Only the wallet itself may authorize deferred fee increases.\\n- The function only permits increasing the balance.\\n- Negative or zero increments are rejected.\\n- Overflow is rejected.\\n\\nBehavior:\\nprevious_deferred_fee + added_base_fee \\xe2\\x86\\x92 updated_deferred_fee\\n\\nNotes:\\n- This function is called when fee is deferred.",
      "name": "update_wallet_deferred_fee",
      "inputs": [
        {
          "doc": "",
          "name": "wallet",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "added_base_fee",
          "type_": "i128"
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": "i128",
            "error_type": {
              "udt": {
                "name": "ContractError"
              }
            }
          }
        }
      ]
    }
  },
