  {
    "function_v0": {
      "doc": "-------------------------------------------------------------------------\\nSettles a wallet's accumulated deferred protocol fees.\\n-------------------------------------------------------------------------\\nSecurity model:\\n- `payer` MUST authorize the payment.\\n- `wallet` identifies the wallet whose deferred fee balance is being settled.\\n- `added_base_fee` allows the caller to atomically include the current\\ntransaction fee into settlement instead of writing deferred state first.\\nNotes:\\n- Passing `added_base_fee = 0` settles only existing deferred fees.\\n- Passing `added_base_fee > 0` is intended for wallet execution flows\\nwhere the current transaction fee should be collected immediately.\\n- Third parties are not allowed to inject additional fees.",
      "name": "settle_wallet_fee",
      "inputs": [
        {
          "doc": "",
          "name": "payer",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "wallet",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "fee_asset",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "added_base_fee",
          "type_": "i128"
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": "void",
            "error_type": {
              "udt": {
                "name": "ContractError"
              }
            }
          }
        }
      ]
    }
  },
