    "function_v0": {
      "doc": "Withdraw collected protocol fees from the fee manager.\\n\\n- Allows the admin to transfer accumulated fee assets out of the contract.\\n\\nValidation:\\n- Caller must be admin.\\n- Asset must be a supported fee asset.\\n- Amount must be positive.\\n- Withdrawal cannot exceed the contract's asset balance.\\n\\nEmits:\\n- WithdrawFeeEvent(asset, amount, to)",
      "name": "withdraw_collected_fees",
      "inputs": [
        {
          "doc": "",
          "name": "asset",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "amount",
          "type_": "i128"
        },
        {
          "doc": "",
          "name": "to",
          "type_": "address"
        }
      ],
      "outputs": [
