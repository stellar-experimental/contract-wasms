  {
    "function_v0": {
      "doc": "Admin/Trident: sync a user's recorded position to their live LP balance\\nand computed tier after externally paying/settling accrued rewards.\\nIf `actual_balance` is zero, the position is removed. If the amount grows\\nor tier increases, the lock timer is reset to the current ledger time.",
      "name": "sync_position",
      "inputs": [
        {
          "doc": "",
          "name": "admin",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "user",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "lp_token",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "actual_balance",
          "type_": "i128"
        },
        {
          "doc": "",
          "name": "new_tier_id",
          "type_": "u32"
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": "void",
            "error_type": {
              "udt": {
                "name": "FarmError"
              }
            }
          }
        }
      ]
    }
  },
