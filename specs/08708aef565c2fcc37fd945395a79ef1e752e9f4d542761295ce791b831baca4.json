  {
    "function_v0": {
      "doc": "Admin/Trident: reduce a user's recorded position when their actual LP\\nbalance has dropped (e.g. they removed liquidity on another platform).\\n`actual_balance` is the user's real LP share balance as observed by the\\nbot via Horizon.  If it's zero the position is removed entirely.\\n`new_tier_id` lets Trident demote the user's tier when their reduced\\nbalance no longer meets the minimum for their current tier.\\nRewards stop accruing on the removed portion from this moment.",
      "name": "slash_position",
      "inputs": [
        {
          "doc": "",
          "name": "admin",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "user",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "lp_token",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "actual_balance",
          "type_": "i128"
        },
        {
          "doc": "",
          "name": "new_tier_id",
          "type_": "u32"
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": "void",
            "error_type": {
              "udt": {
                "name": "FarmError"
              }
            }
          }
        }
      ]
    }
  },
