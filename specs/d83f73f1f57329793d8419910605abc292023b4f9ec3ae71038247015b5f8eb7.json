    "function_v0": {
      "doc": "SCHEDULED TRANSFER: Transfer USDC using a unique tx_id (for scheduled/auto-pay).\\n\\nThis version uses a unique transaction ID instead of sequential nonce,\\nallowing transactions to be executed in ANY order.\\n\\nEach tx_id can only be used once. Perfect for:\\n- Scheduled payments (execute at specific time)\\n- Recurring payments (pre-sign multiple with different tx_ids)\\n- Out-of-order execution\\n\\nThe challenge format: SHA256(\"scheduled_transfer\" | recipient | amount | tx_id | deadline)\\n\\n`tx_id`: A unique 32-byte identifier (e.g., random bytes or hash of tx details)\\n`deadline`: Unix timestamp after which this tx is invalid (0 = no deadline)",
      "name": "scheduled_transfer",
      "inputs": [
        {
          "doc": "",
          "name": "recipient",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "amount",
          "type_": "i128"
        },
        {
          "doc": "",
          "name": "tx_id",
          "type_": {
            "bytes_n": {
              "n": 32
            }
          }
        },
        {
          "doc": "",
          "name": "deadline",
          "type_": "u64"
        },
        {
          "doc": "",
          "name": "signature",
          "type_": {
            "bytes_n": {
              "n": 64
            }
          }
        },
