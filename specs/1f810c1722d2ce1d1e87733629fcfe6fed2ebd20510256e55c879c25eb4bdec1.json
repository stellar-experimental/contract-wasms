    "function_v0": {
      "doc": "Execute swap via Aquarius (K2 standard interface)\\n\\nThis is called by K2 contracts. It translates K2's simple interface\\nto Aquarius's specific requirements (sorted tokens, pool_index, etc.)\\n\\n# Arguments\\n* `from_token` - Token to swap from\\n* `to_token` - Token to swap to\\n* `amount_in` - Amount to swap\\n* `min_amount_out` - Minimum acceptable output (slippage protection)\\n* `recipient` - Address to receive output tokens\\n\\n# Returns\\n* Actual amount of tokens received",
      "name": "execute_swap",
      "inputs": [
        {
          "doc": "",
          "name": "from_token",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "to_token",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "amount_in",
          "type_": "u128"
        },
        {
          "doc": "",
