  {
    "function_v0": {
      "doc": "Set the external price of one OTHER raw unit in USDC raw units, as the\\nrational `num / den`. Required for non-1:1 pairs (e.g. USDC/EURC must be\\nset to the EUR/USD rate); a 1:1 equal-decimal peg can leave the (1, 1)\\ndefault. Both components are bounded to `[1, MAX_PRICE_COMPONENT]` so a\\nmisconfiguration cannot overflow `balance_of`'s fair-LP math.",
      "name": "set_price",
      "inputs": [
        {
          "doc": "",
          "name": "caller",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "num",
          "type_": "i128"
        },
        {
          "doc": "",
          "name": "den",
          "type_": "i128"
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": "void",
            "error_type": {
              "udt": {
                "name": "StrategyError"
              }
            }
          }
        }
      ]
    }
  },
