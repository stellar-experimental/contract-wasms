  {
    "function_v0": {
      "doc": "Withdraw `amount` USDC by burning the proportional fraction of LP.\\n\\nSteps:\\n1. Compute LP fraction = amount / current_lp_value_usdc\\n2. `remove_liquidity` to receive USDC + OTHER\\n3. Swap OTHER \\xe2\\x86\\x92 USDC, slippage-guarded\\n4. Transfer total USDC out to caller (vault)\\n5. Update `tracked_balance`\\n\\nCaps to actual position value if `amount` exceeds it. Returns the\\nactual USDC delivered.",
      "name": "withdraw",
      "inputs": [
        {
          "doc": "",
          "name": "caller",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "amount",
          "type_": "i128"
        }
      ],
