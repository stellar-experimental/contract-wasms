  {
    "function_v0": {
      "doc": "Single-sided zap-in: USDC \\xe2\\x86\\x92 LP.\\n\\nSteps:\\n1. Read live pool reserves\\n2. Compute optimal swap split (`zap::optimal_swap_amount`)\\n3. Swap `swap_in` USDC \\xe2\\x86\\x92 OTHER, slippage-guarded\\n4. `add_liquidity(USDC_remaining, OTHER_received)`, slippage-guarded\\n5. Update `tracked_balance += amount`\\n\\nVault MUST pre-transfer `amount` USDC to this contract before calling.\\nAny LP minted plus any USDC/OTHER dust stays in the strategy and is\\nreflected in `balance_of`.",
      "name": "deposit",
      "inputs": [
        {
          "doc": "",
          "name": "caller",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "amount",
          "type_": "i128"
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": "void",
            "error_type": {
              "udt": {
                "name": "StrategyError"
              }
            }
          }
        }
      ]
    }
  },
