[
  {
    "udt_struct_v0": {
      "doc": "A single public key entry in a `DidRecord`.\\n\\n`public_key_multibase` follows the W3C Multikey encoding (for example,\\n`z6Mk...` for Ed25519, `z6LS...` for X25519).",
      "lib": "",
      "name": "DidKey",
      "fields": [
        {
          "doc": "Multikey-encoded public key.",
          "name": "public_key_multibase",
          "type_": "string"
        }
      ]
    }
  },
  {
    "udt_struct_v0": {
      "doc": "On-chain DID record. One entry per DID, keyed by a 16-byte `did_id`.",
      "lib": "",
      "name": "DidRecord",
      "fields": [
        {
          "doc": "Assertion-method keys (0\\xe2\\x80\\x933).",
          "name": "assertion_method",
          "type_": {
            "vec": {
              "element_type": {
                "udt": {
                  "name": "DidKey"
                }
              }
            }
          }
        },
        {
          "doc": "Authentication keys (1\\xe2\\x80\\x933).",
          "name": "authentication",
          "type_": {
            "vec": {
              "element_type": {
                "udt": {
                  "name": "DidKey"
                }
              }
            }
          }
        },
        {
          "doc": "Stellar account that authorizes mutations on this DID.",
          "name": "controller",
          "type_": "address"
        },
        {
          "doc": "Ledger number at registration. Never changes after `register`.",
          "name": "created_ledger",
          "type_": "u32"
        },
        {
          "doc": "One-way deactivation flag. Once `true` it can never be reset.",
          "name": "deactivated",
          "type_": "bool"
        },
        {
          "doc": "Key-agreement keys (0\\xe2\\x80\\x931).",
          "name": "key_agreement",
          "type_": {
            "vec": {
              "element_type": {
                "udt": {
                  "name": "DidKey"
                }
              }
            }
          }
        },
        {
          "doc": "Optional SHA-256 digest of the off-chain metadata payload.",
          "name": "metadata_hash",
          "type_": {
            "option": {
              "value_type": {
                "bytes_n": {
                  "n": 32
                }
              }
            }
          }
        },
        {
          "doc": "Optional URI to extended off-chain metadata (HTTPS only).",
          "name": "metadata_uri",
          "type_": {
            "option": {
              "value_type": "string"
            }
          }
        },
        {
          "doc": "Service endpoints (0\\xe2\\x80\\x933).",
          "name": "services",
          "type_": {
            "vec": {
              "element_type": {
                "udt": {
                  "name": "DidService"
                }
              }
            }
          }
        },
        {
          "doc": "Ledger number of the most recent successful mutation.",
          "name": "updated_ledger",
          "type_": "u32"
        },
        {
          "doc": "Mutation counter. Starts at 1 and is incremented on every successful\\nmutation. Used for optimistic concurrency.",
          "name": "version",
          "type_": "u32"
        }
      ]
    }
  },
  {
    "udt_struct_v0": {
      "doc": "A service entry in a `DidRecord`.\\n\\nIn the resolved DID Document each service becomes\\n`{did}#service-{id_suffix}`.",
      "lib": "",
      "name": "DidService",
      "fields": [
        {
          "doc": "Lowercase alphanumeric + hyphen. Used as the fragment in the DID URL.",
          "name": "id_suffix",
          "type_": "string"
        },
        {
          "doc": "Absolute HTTPS URL.",
          "name": "service_endpoint",
          "type_": "string"
        },
        {
          "doc": "Free string. Mapped to `type` in the resolved DID Document.",
          "name": "service_type",
          "type_": "string"
        }
      ]
    }
  },
  {
    "udt_error_enum_v0": {
      "doc": "",
      "lib": "",
      "name": "RegistryError",
      "cases": [
        {
          "doc": "`register` called with a `did_id` that already has a record.",
          "name": "DidAlreadyExists",
          "value": 1
        },
        {
          "doc": "`update`/`transfer_controller`/`deactivate` called for an unknown DID.",
          "name": "DidNotFound",
          "value": 2
        },
        {
          "doc": "`expected_version` does not match the current on-chain `version`.",
          "name": "VersionMismatch",
          "value": 3
        },
        {
          "doc": "Mutation attempted on a record where `deactivated == true`.",
          "name": "DidDeactivated",
          "value": 4
        },
        {
          "doc": "`authentication` count is outside [MIN_KEY_COUNT_AUTH, MAX_KEY_COUNT_AUTH].",
          "name": "InvalidAuthKeyCount",
          "value": 5
        },
        {
          "doc": "`assertion_method` count exceeds MAX_KEY_COUNT_ASSERT.",
          "name": "InvalidAssertionKeyCount",
          "value": 6
        },
        {
          "doc": "`key_agreement` count exceeds MAX_KEY_COUNT_AGREEMENT.",
          "name": "InvalidKeyAgreementCount",
          "value": 7
        },
        {
          "doc": "`services` count exceeds MAX_SERVICE_COUNT.",
          "name": "InvalidServiceCount",
          "value": 8
        },
        {
          "doc": "Same `public_key_multibase` appears twice in a single relationship.",
          "name": "DuplicateKey",
          "value": 9
        },
        {
          "doc": "`public_key_multibase` exceeds MAX_KEY_MULTIBASE_LEN.",
          "name": "KeyTooLong",
          "value": 10
        },
        {
          "doc": "`public_key_multibase` is empty.",
          "name": "KeyEmpty",
          "value": 11
        },
        {
          "doc": "`service.service_type` exceeds MAX_SERVICE_TYPE_LEN.",
          "name": "ServiceTypeTooLong",
          "value": 12
        },
        {
          "doc": "`service.id_suffix` exceeds MAX_SERVICE_ID_LEN.",
          "name": "ServiceIdTooLong",
          "value": 13
        },
        {
          "doc": "`service.id_suffix` does not match `^[a-z0-9-]+$`.",
          "name": "ServiceIdInvalidFormat",
          "value": 14
        },
        {
          "doc": "`service.service_endpoint` is not an `https://` URL or exceeds MAX_URL_LEN.",
          "name": "ServiceEndpointInvalid",
          "value": 15
        },
        {
          "doc": "`metadata_uri` is not an `https://` URL or exceeds MAX_URL_LEN.",
          "name": "MetadataUriInvalid",
          "value": 16
        },
        {
          "doc": "`accept_admin` called when no admin has been proposed (or the\\nproposal expired from temporary storage).",
          "name": "NoProposedAdmin",
          "value": 17
        },
        {
          "doc": "`service.service_type` is empty.",
          "name": "ServiceTypeEmpty",
          "value": 18
        },
        {
          "doc": "`update`/`transfer_controller`/`deactivate` called on a DID whose\\n`version` has reached `u32::MAX`. Extremely unlikely in practice but\\nmust be handled to prevent arithmetic overflow.",
          "name": "VersionOverflow",
          "value": 19
        },
        {
          "doc": "`metadata_hash` is `Some` but `metadata_uri` is `None`. An integrity\\nhash without a corresponding URI is orphaned and meaningless.",
          "name": "MetadataInconsistent",
          "value": 20
        },
        {
          "doc": "Two services share the same `id_suffix`, which would produce duplicate\\n`{did}#service-{id_suffix}` fragments in the resolved DID Document.",
          "name": "DuplicateServiceId",
          "value": 21
        }
      ]
    }
  },
