              }
            }
          }
        }
      ]
    }
  },
  {
    "function_v0": {
      "doc": "Proposes a new proposal. The owner must be the signer of the transaction, and the proposal\\nmust be valid (and not an Invoke variant since Invoke proposals are not\\nallowed to be directly proposed).\\n\\nProposals have a short TTL (approximately 1 week) and can be implicitly prematurely revoked if the\\nconfig is changed.",
      "name": "propose",
      "inputs": [
        {
          "doc": "",
          "name": "owner",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "proposal",
          "type_": {
            "udt": {
              "name": "ProposalInput"
            }
          }
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": {
              "udt": {
                "name": "Proposal"
              }
            },
            "error_type": {
              "udt": {
                "name": "ContractError"
              }
            }
          }
        }
      ]
    }
  },
