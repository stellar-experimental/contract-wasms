[
  {
    "function_v0": {
      "doc": "Vote on a proposal. The caller must be an owner and the proposal must be pending.\\nAn error is returned if the proposal is not pending, the caller is not an owner,\\nor the voter has already voted (votes cannot be changed once cast).",
      "name": "vote",
      "inputs": [
        {
          "doc": "",
          "name": "owner",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "proposal_id",
          "type_": "u64"
        },
        {
          "doc": "",
          "name": "vote",
          "type_": {
            "udt": {
              "name": "VoteType"
            }
          }
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": {
              "udt": {
                "name": "Proposal"
              }
            },
            "error_type": {
              "udt": {
                "name": "ContractError"
              }
            }
          }
        }
      ]
    }
  },
  {
    "function_v0": {
      "doc": "Propose a new invoke proposal to invoke an arbitrary contract function.\\nThe caller must be an owner and the invoke must be valid (i.e. the contract exists and the function is valid).\\nInvoke proposals require (threshold - 1) additional votes since the proposer auto-votes Yes.",
      "name": "invoke",
      "inputs": [
        {
          "doc": "",
          "name": "caller",
          "type_": "address"
        },
        {
          "doc": "",
