  {
    "function_v0": {
      "doc": "Re-extend the TTL of the oracle instance storage.\\n\\nThis is a **permissionless** function \\xe2\\x80\\x94 anyone can call it and the\\ncaller pays the transaction fees.\\n\\nThe `ledgers` parameter specifies the desired TTL extension in\\nledgers (clamped to the network's `max_ttl`). For long-maturity\\noracles where the network max TTL (~6 months) is shorter than\\nthe time to maturity, callers should invoke `bump()` periodically.\\n\\nSoroban's `extend_ttl` is monotonic (it never shrinks a TTL), so\\ncalling this when TTLs are already healthy is a safe no-op.\\n\\n# Errors\\n* `NotInitialized` - Contract has not been initialized",
      "name": "bump",
      "inputs": [
        {
          "doc": "",
          "name": "ledgers",
          "type_": "u32"
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": {
              "tuple": {
                "value_types": []
              }
            },
            "error_type": {
              "udt": {
                "name": "OracleError"
              }
            }
          }
        }
      ]
    }
  },
  {
    "function_v0": {
      "doc": "Get price at a specific timestamp.\\n\\nReturns `None` if:\\n- The oracle is not initialized\\n- The timestamp is before the oracle start time\\n- The price computation overflows",
