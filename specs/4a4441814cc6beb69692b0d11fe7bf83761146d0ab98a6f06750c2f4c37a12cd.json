  {
    "function_v0": {
      "doc": "Initialize the oracle with the required parameters.\\n\\n# Arguments\\n* `owner` - The owner address (can update config and transfer ownership)\\n* `upgrader` - The upgrader address (can upgrade the contract WASM)\\n* `pt` - The PT token address being priced\\n* `maturity` - The maturity timestamp (Unix timestamp)\\n* `initial_implied_apy` - The initial implied APY (18 decimals, e.g., 0.1e18 = 10%)\\n* `future_pt_value` - The future PT value at maturity (in `decimals` precision)\\n* `decimals` - The number of decimals for the price output\\n\\n# Errors\\n* `AlreadyInitialized` - Contract has already been initialized\\n* `InvalidMaturity` - Maturity timestamp is not in the future\\n* `InvalidApy` - APY is not between 0 and 100%\\n* `InvalidFuturePtValue` - Future PT value is not positive",
      "name": "initialize",
      "inputs": [
        {
          "doc": "",
          "name": "owner",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "upgrader",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "pt",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "maturity",
          "type_": "u64"
        },
        {
          "doc": "",
          "name": "initial_implied_apy",
          "type_": "i128"
        },
        {
          "doc": "",
          "name": "future_pt_value",
          "type_": "i128"
        },
        {
          "doc": "",
          "name": "decimals",
          "type_": "u32"
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": {
              "tuple": {
                "value_types": []
              }
            },
            "error_type": {
              "udt": {
                "name": "OracleError"
              }
            }
          }
        }
      ]
    }
  },
