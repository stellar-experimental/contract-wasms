[
  {
    "function_v0": {
      "doc": "Initialize the treasury contract with an admin address.\\n\\nThe admin address is a single account.\\nOnce initialized, the contract cannot be reinitialized. This ensures the admin\\naddress remains consistent and prevents accidental reconfiguration.\\n\\n# Arguments\\n* `env` - The execution environment\\n* `admin` - Address of the admin (can be multisig contract for enhanced security)\\n\\n# Returns\\n* `Ok(())` - Treasury initialized successfully\\n* `Err(TreasuryError)` - Initialization failed (e.g., already initialized)",
      "name": "initialize",
      "inputs": [
        {
          "doc": "",
          "name": "admin",
          "type_": "address"
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": {
              "tuple": {
                "value_types": []
              }
            },
            "error_type": {
              "udt": {
                "name": "TreasuryError"
              }
            }
          }
        }
      ]
    }
  },
  {
    "function_v0": {
      "doc": "Record a deposit of tokens to the treasury.\\n\\nThis function updates internal balance tracking after tokens have been transferred\\nto the treasury contract address. The actual token transfer must occur via the\\ntoken contract's transfer function before calling this method. This separation\\nallows the treasury to track protocol fees collected from various sources.\\n\\n# Arguments\\n* `env` - The execution environment\\n* `asset` - Address of the token contract\\n* `amount` - Amount of tokens being deposited (must be > 0)\\n* `from` - Address that sent the tokens (for event tracking and audit trail)\\n\\n# Returns\\n* `Ok(())` - Deposit recorded successfully\\n* `Err(TreasuryError)` - Deposit failed (not initialized, invalid amount, or overflow)",
      "name": "deposit",
      "inputs": [
        {
          "doc": "",
          "name": "asset",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "amount",
          "type_": "u128"
        },
        {
          "doc": "",
          "name": "from",
          "type_": "address"
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": {
              "tuple": {
                "value_types": []
              }
            },
            "error_type": {
              "udt": {
                "name": "TreasuryError"
              }
            }
          }
        }
      ]
    }
  },
  {
    "function_v0": {
      "doc": "Sync balance from token contract and update internal tracking.\\n\\nThis function queries the token contract's balance function to reconcile the\\nactual balance held by the treasury with internal tracking. Use this when tokens\\nare transferred directly to the treasury address without calling deposit(), such\\nas when protocol fees are collected automatically.\\n\\n# Arguments\\n* `env` - The execution environment\\n* `asset` - Address of the token contract\\n\\n# Returns\\n* `Ok(u128)` - Current balance synced from token contract\\n* `Err(TreasuryError)` - Sync failed (not initialized or token contract query failed)",
      "name": "sync_balance",
      "inputs": [
        {
          "doc": "",
          "name": "asset",
          "type_": "address"
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": "u128",
            "error_type": {
              "udt": {
                "name": "TreasuryError"
              }
            }
          }
        }
      ]
    }
  },
  {
    "function_v0": {
      "doc": "Withdraw tokens from the treasury (admin only).\\n\\nThis function performs two critical operations atomically: it updates internal\\nbalance tracking and transfers tokens to the recipient. If the token transfer\\nfails, the balance update is reverted, ensuring consistency. Only authorized\\nadmins (or multisig contract if configured) can perform withdrawals.\\n\\n# Arguments\\n* `env` - The execution environment\\n* `caller` - Admin address (must be authorized - regular admin or multisig contract)\\n* `asset` - Address of the token contract to withdraw\\n* `amount` - Amount of tokens to withdraw (must be > 0 and <= available balance)\\n* `to` - Address to receive the tokens\\n\\n# Returns\\n* `Ok(())` - Withdrawal successful (balance updated and tokens transferred)\\n* `Err(TreasuryError)` - Withdrawal failed (unauthorized, insufficient balance, or transfer failed)",
      "name": "withdraw",
      "inputs": [
        {
          "doc": "",
          "name": "caller",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "asset",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "amount",
          "type_": "u128"
        },
        {
          "doc": "",
          "name": "to",
          "type_": "address"
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": {
              "tuple": {
                "value_types": []
              }
            },
            "error_type": {
              "udt": {
                "name": "TreasuryError"
              }
            }
          }
        }
      ]
    }
  },
  {
    "function_v0": {
      "doc": "Get the balance of a specific asset in the treasury.\\n\\nReturns the internally tracked balance for the given asset. This may differ\\nfrom the actual token contract balance if sync_balance() hasn't been called\\nafter direct transfers to the treasury address.\\n\\n# Arguments\\n* `env` - The execution environment\\n* `asset` - Address of the token contract\\n\\n# Returns\\n* `u128` - Balance of the asset (0 if asset has never been deposited)",
      "name": "get_balance",
      "inputs": [
        {
          "doc": "",
          "name": "asset",
          "type_": "address"
        }
      ],
      "outputs": [
        "u128"
      ]
    }
  },
  {
    "function_v0": {
      "doc": "Get all balances in the treasury.\\n\\nReturns a map of all assets that have been deposited to the treasury along\\nwith their tracked balances. Assets with zero balance are not included in\\nthe map.\\n\\n# Arguments\\n* `env` - The execution environment\\n\\n# Returns\\n* `Map<Address, u128>` - Map of asset addresses to their balances",
      "name": "get_all_balances",
      "inputs": [],
      "outputs": [
        {
          "map": {
            "key_type": "address",
            "value_type": "u128"
          }
        }
      ]
    }
  },
  {
    "function_v0": {
      "doc": "Get the admin address.\\n\\n# Arguments\\n* `env` - The execution environment\\n\\n# Returns\\n* `Address` - Admin address",
      "name": "get_admin",
      "inputs": [],
      "outputs": [
        "address"
      ]
    }
  },
