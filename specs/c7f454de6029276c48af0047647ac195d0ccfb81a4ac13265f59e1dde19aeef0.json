  {
    "function_v0": {
      "doc": "* @notice Allows a borrower to repay their loan linked to a specific invoice.\\n     * @dev Repayment can be either full or partial. The function updates the\\n     *      outstanding balance of the invoice and adjusts pool state accordingly.\\n     *\\n     * @param invoice_id   Unique identifier of the invoice tied to the loan.\\n     * @param amount     Amount being repaid (can be less than or equal to the outstanding loan).",
      "name": "repay_loan",
      "inputs": [
        {
          "doc": "",
          "name": "invoice_id",
          "type_": "string"
        },
        {
          "doc": "",
          "name": "amount",
          "type_": "u128"
        }
      ],
      "outputs": []
    }
  },
  {
    "function_v0": {
      "doc": "* @notice Allows a lender to participate in the pool by contributing USD tokens.\\n     * @dev\\n     * - Transfers USD tokens from the lender to the pool.\\n     * - Issues LP tokens to the lender proportional to their contribution.\\n     * - Updates pool state including total raised amount and lender details.\\n     * @param lender The address of the lender providing funds.\\n     * @param amount The amount of USD tokens the lender contributes.",
      "name": "participate",
      "inputs": [
        {
          "doc": "",
          "name": "lender",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "amount",
          "type_": "u128"
        }
      ],
      "outputs": []
    }
  },
  {
    "function_v0": {
      "doc": "* @notice Accept the admin role.\\n     * @dev Can only be called by the pending admin proposed earlier via `propose_new_admin()`.\\n     *      Once accepted, the pending admin becomes the active admin,\\n     *      and the pending slot is reset to zero.",
      "name": "accept_admin",
      "inputs": [],
      "outputs": []
    }
  },
  {
    "function_v0": {
      "doc": "* @notice Executes a pool by allocating funds to the specified invoices.\\n     * @dev Used when the pool becomes active. Distributes or locks capital\\n     *      against the provided invoice IDs with their respective amounts.\\n     *\\n     * @param invoicesids   Array of invoice identifiers to be executed within the pool.\\n     * @param amounts       Array of amounts to be allocated for each corresponding invoice.",
      "name": "execute_pool",
      "inputs": [
        {
          "doc": "",
          "name": "invoicesids",
          "type_": {
