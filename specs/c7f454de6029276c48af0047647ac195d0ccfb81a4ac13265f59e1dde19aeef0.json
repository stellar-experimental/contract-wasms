    "function_v0": {
      "doc": "* @notice Allows a lender to claim their LP tokens after repayment.\\n     * @dev Once borrowers repay, lenders can claim LP tokens that represent\\n     *      their share of the repayment and yield. The distribution is done\\n     *      proportionally based on each lender\\xe2\\x80\\x99s pool share.\\n     *\\n     * @param lender_addr   Address of the lender claiming their LP tokens.",
      "name": "claim_lp_token",
      "inputs": [
        {
          "doc": "",
          "name": "lender_addr",
          "type_": "address"
        }
      ],
      "outputs": []
    }
  },
  {
    "function_v0": {
      "doc": "* @notice Fills the insurance fund for specific invoices.\\n     * @dev Only callable by the admin (secured with `onlyAdminSafe`).\\n     *      The insurance amount is funded from the admin/treasury wallet\\n     *      and credited to the pool contract. These funds act as protection\\n     *      for lenders in case of borrower default.\\n     *\\n     * @param invoices   Array of invoice identifiers that will be insured.\\n     * @param amounts    Array of insurance amounts allocated to each corresponding invoice.",
      "name": "fill_insurance",
      "inputs": [
        {
          "doc": "",
          "name": "invoices",
          "type_": {
            "vec": {
              "element_type": "string"
            }
          }
        },
        {
          "doc": "",
          "name": "amounts",
          "type_": {
            "vec": {
              "element_type": "u128"
            }
          }
        }
      ],
      "outputs": []
    }
  },
