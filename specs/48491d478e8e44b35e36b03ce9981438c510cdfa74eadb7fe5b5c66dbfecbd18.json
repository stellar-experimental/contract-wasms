  {
    "function_v0": {
      "doc": "Returns the maximum decimal precision across all registered feeds.\\n\\n**Deviation from SEP-40:** The standard requires `decimals` to be\\nimmutable after deployment. This implementation does not uphold that\\nguarantee: the value increases when a feed with higher precision is\\nadded and may decrease when the feed that currently defines the\\nmaximum is removed. The value is stable within a single transaction\\n\\xe2\\x80\\x94 it can only change through owner-gated admin calls (`add_feed`,\\n`remove_feed`, `update_feed`). Integrators must not cache this value\\nacross administrative operations.",
      "name": "decimals",
      "inputs": [],
      "outputs": [
        "u32"
      ]
    }
