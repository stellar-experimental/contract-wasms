  {
    "function_v0": {
      "doc": "Request an asynchronous redemption by asset amount.\\n\\nThis is an ERC-7540-style redemption request, not a synchronous\\nERC-4626 withdrawal. It escrows shares in the vault and returns a\\n`request_id`; assets are not transferred to `receiver` until the\\nwithdrawal becomes executable and `execute_withdraw` succeeds.\\n\\n`operator` is explicit because Soroban has no ambient `msg.sender`.\\nThe supported path is `operator == owner`. Operator-style delegated\\nrequests require a transfer-from-backed vault request path.",
      "name": "withdraw",
      "inputs": [
        {
          "doc": "",
          "name": "operator",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "assets",
          "type_": "i128"
        },
        {
          "doc": "",
          "name": "receiver",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "owner",
          "type_": "address"
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": "u64",
            "error_type": {
              "udt": {
                "name": "ContractError"
              }
            }
          }
        }
      ]
    }
  },
  {
