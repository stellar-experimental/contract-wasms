    "function_v0": {
      "doc": "Synchronous asset deposit into the underlying vault.\\n\\n`operator` is explicit because Soroban has no ambient `msg.sender`; the\\nproxy must know which address to authenticate with `require_auth()`.\\nThis method follows the ERC-4626 deposit shape, but with the Soroban\\noperator address passed as an argument. The operator is also the asset\\nsource for this compatibility entrypoint.",
      "name": "deposit",
      "inputs": [
        {
          "doc": "",
          "name": "operator",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "assets",
          "type_": "i128"
        },
        {
          "doc": "",
          "name": "receiver",
          "type_": "address"
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": "i128",
            "error_type": {
              "udt": {
                "name": "ContractError"
              }
            }
          }
        }
      ]
    }
