  {
    "function_v0": {
      "doc": "Initializes the factory with an administrator and pool WASM hash.\\n\\nSets up the factory with default fee tiers matching Uniswap V3:\\n- 0.05% (500 bps) with tick spacing 10 (for stablecoin pairs)\\n- 0.3% (3000 bps) with tick spacing 60 (for most pairs)\\n- 1% (10000 bps) with tick spacing 200 (for exotic pairs)\\n\\nInitializes protocol fees to 0.\\n\\n# Arguments\\n* `env` - The contract environment\\n* `admin` - Address of the factory owner\\n* `wasm_hash` - WASM hash of the pool contract to deploy\\n* `flash_executor` - Address of the FlashExecutor contract (immutable)\\n\\n# Flash Executor\\nThe flash_executor is set once at initialization and cannot be changed.\\nThis immutability provides:\\n- Decentralization: No admin can update the executor\\n- Security: Flash loan behavior is predictable and unchangeable\\n- Trust: Users know the executor contract will never change",
      "name": "__constructor",
      "inputs": [
        {
          "doc": "",
          "name": "admin",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "wasm_hash",
          "type_": {
            "bytes_n": {
              "n": 32
            }
          }
        },
        {
          "doc": "",
          "name": "flash_executor",
          "type_": "address"
        }
      ],
      "outputs": []
    }
  },
  {
