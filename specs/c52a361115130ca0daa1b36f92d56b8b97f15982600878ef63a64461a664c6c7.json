            "bytes_n": {
              "n": 32
            }
          }
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": "void",
            "error_type": {
              "udt": {
                "name": "AgeVerifierError"
              }
            }
          }
        }
      ]
    }
  },
  {
    "function_v0": {
      "doc": "Verify a Groth16 proof and mint a soulbound credential to the caller.\\n\\n`pub_inputs` \\xe2\\x80\\x94 must have exactly 3 elements in this order:\\n[0] isOldEnough   (Fr with value 1)\\n[1] commitment    (Fr = Poseidon(birthDate, addressHash))\\n[2] addressHash   (Fr derived from caller's Stellar address)\\n\\n`nullifier`   \\xe2\\x80\\x94 unique 32-byte value preventing proof replay.\\nRecommended: random bytes generated client-side per submission.\\n\\n`issuer_sig`  \\xe2\\x80\\x94 Ed25519 signature (64 bytes) from the trusted Issuer over\\nthe raw bytes of commitment (pub_inputs[1]).\\nThe Issuer produces this during KYC after verifying the user's document.",
      "name": "verify",
      "inputs": [
        {
          "doc": "",
          "name": "proof",
          "type_": {
            "udt": {
              "name": "Groth16Proof"
            }
          }
        },
        {
          "doc": "",
          "name": "pub_inputs",
          "type_": {
            "vec": {
              "element_type": "u256"
            }
          }
        },
        {
          "doc": "",
          "name": "nullifier",
          "type_": {
            "bytes_n": {
              "n": 32
            }
          }
        },
        {
          "doc": "",
          "name": "issuer_sig",
          "type_": {
            "bytes_n": {
              "n": 64
            }
          }
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": "bool",
            "error_type": {
              "udt": {
                "name": "AgeVerifierError"
              }
            }
          }
        }
      ]
    }
  },
