  {
    "function_v0": {
      "doc": "Execute a split-order swap atomically.\\n\\nSplits the input across multiple paths for better execution:\\ne.g., 30% via Soroswap (A\\xe2\\x86\\x92B), 70% via Aquarius (A\\xe2\\x86\\x92C\\xe2\\x86\\x92B)\\n\\nFlow:\\n1. Pull total `amount_in` of `token_in` from user\\n2. For each sub-route: execute its path with its allocated amount\\n3. Sum all outputs (must all produce the same `token_out`)\\n4. Verify total output >= `min_amount_out`\\n5. Transfer total output to user\\n\\nAll sub-routes MUST produce the same output token.",
      "name": "split_swap",
      "inputs": [
        {
          "doc": "",
          "name": "user",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "token_in",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "token_out",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "sub_routes",
          "type_": {
            "vec": {
              "element_type": {
                "udt": {
                  "name": "SubRoute"
                }
              }
            }
          }
        },
        {
          "doc": "",
          "name": "min_amount_out",
          "type_": "i128"
        }
      ],
      "outputs": [
        "i128"
      ]
    }
  },
  {
    "udt_struct_v0": {
      "doc": "A sub-route in a split order.\\nEach sub-route has its own amount and path (sequence of swap steps).",
      "lib": "",
      "name": "SubRoute",
      "fields": [
        {
          "doc": "Amount of input token allocated to this sub-route",
          "name": "amount_in",
          "type_": "i128"
        },
        {
          "doc": "Swap steps for this sub-route (multi-hop path)",
          "name": "steps",
          "type_": {
            "vec": {
              "element_type": {
                "udt": {
                  "name": "SwapStep"
                }
              }
            }
          }
        }
      ]
    }
  },
  {
    "udt_struct_v0": {
      "doc": "A single swap step in the aggregation path",
      "lib": "",
