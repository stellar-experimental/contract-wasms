            }
          }
        },
        {
          "doc": "Input token index in the pool's token list (0-based)",
          "name": "in_idx",
          "type_": "u32"
        },
        {
          "doc": "Output token index in the pool's token list (0-based)",
          "name": "out_idx",
          "type_": "u32"
        },
        {
          "doc": "Input token for this step",
          "name": "token_in",
          "type_": "address"
        },
        {
          "doc": "Output token for this step",
          "name": "token_out",
          "type_": "address"
        }
      ]
    }
  }
