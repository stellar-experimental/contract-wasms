  {
    "function_v0": {
      "doc": "Buy outcome tokens.\\n\\n# Arguments\\n* `user` - User buying tokens (must authorize)\\n* `outcome` - 0 for YES, 1 for NO\\n* `amount` - Amount of tokens to buy (scaled by 10^7)\\n* `max_cost` - Maximum collateral willing to pay (slippage protection).\\nThe transaction reverts if calculated cost exceeds this value,\\nprotecting users from price movements between quote and execution.\\n\\n# Returns\\nActual cost paid in collateral",
      "name": "buy",
      "inputs": [
        {
          "doc": "",
          "name": "user",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "outcome",
          "type_": "u32"
        },
        {
          "doc": "",
          "name": "amount",
          "type_": "i128"
        },
        {
          "doc": "",
          "name": "max_cost",
          "type_": "i128"
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": "i128",
            "error_type": {
              "udt": {
                "name": "MarketError"
              }
            }
          }
        }
      ]
    }
  },
