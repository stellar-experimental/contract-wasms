    "udt_struct_v0": {
      "doc": "Per-bid ephemeral sealed payload (Temporary). Auto-expires after the reveal\\nwindow; the auto-expiry is the design, not a workaround (PRD \\xc2\\xa78).",
      "lib": "",
      "name": "Seal",
