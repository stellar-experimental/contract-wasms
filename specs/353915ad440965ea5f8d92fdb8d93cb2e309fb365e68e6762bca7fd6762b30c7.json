  {
    "function_v0": {
      "doc": "Submit (or overwrite, before the deadline) a sealed bid and lock escrow.\\n\\n- `commitment` H binds the bid; checked at reveal.\\n- `ciphertext` C is the timelock seal; guarantees forced reveal.\\n- `escrow` is a public USDC budget and an upper bound on the sealed bid;\\nlocked now so the winner can always pay.\\n- `auditor_blob` is the bidder identity encrypted to the auditor key.",
      "name": "commit",
      "inputs": [
        {
          "doc": "",
          "name": "round_id",
          "type_": "u64"
        },
        {
          "doc": "",
          "name": "bidder",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "commitment",
          "type_": {
            "bytes_n": {
              "n": 32
            }
          }
        },
        {
          "doc": "",
          "name": "ciphertext",
          "type_": "bytes"
        },
        {
          "doc": "",
          "name": "escrow",
          "type_": "i128"
        },
        {
          "doc": "",
          "name": "auditor_blob",
          "type_": "bytes"
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": {
              "tuple": {
                "value_types": []
              }
            },
            "error_type": "error"
          }
        }
      ]
    }
  },
  {
    "function_v0": {
      "doc": "Reveal a bid. Permissionless: once R's signature is public, anyone can\\ndecrypt any ciphertext and submit the reveal \\xe2\\x80\\x94 so no bidder can abort.\\nThe contract checks `sha256(be16(value) \\xe2\\x80\\x96 nonce) == H`.",
      "name": "reveal",
      "inputs": [
