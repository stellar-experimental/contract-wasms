        },
        {
          "doc": "",
          "name": "value",
          "type_": "i128"
        },
        {
          "doc": "",
          "name": "nonce",
          "type_": {
            "bytes_n": {
              "n": 32
            }
          }
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": {
              "tuple": {
                "value_types": []
              }
            },
            "error_type": "error"
          }
        }
      ]
    }
  },
