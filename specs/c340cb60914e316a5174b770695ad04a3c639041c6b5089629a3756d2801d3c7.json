[
  {
    "udt_enum_v0": {
      "doc": "Action discriminator used by the per-chain gas-usage table.",
      "lib": "",
      "name": "Action",
      "cases": [
        {
          "doc": "",
          "name": "Router",
          "value": 0
        },
        {
          "doc": "",
          "name": "Swap",
          "value": 1
        }
      ]
    }
  },
  {
    "udt_struct_v0": {
      "doc": "Calldata for `send_token`. Mirrors the EVM `Router.SendParams` struct.",
      "lib": "",
      "name": "SendParams",
      "fields": [
        {
          "doc": "Amount of `source_token` provided by the sender (in source-token\\nnative decimals, e.g. 7-decimal subunits for Stellar USDC).",
          "name": "amount",
          "type_": "i128"
        },
        {
          "doc": "32-byte destination recipient address.",
          "name": "destination_address",
          "type_": {
            "bytes_n": {
              "n": 32
            }
          }
        },
        {
          "doc": "Destination chain id (Allbridge protocol id, not the CCTP domain).",
          "name": "destination_chain",
          "type_": "u32"
        },
        {
          "doc": "32-byte destination token address (chain-specific encoding).",
          "name": "destination_token",
          "type_": {
            "bytes_n": {
              "n": 32
            }
          }
        },
        {
          "doc": "Amount of native gas token (XLM stroops) the sender is paying to\\nsettle the cross-chain relayer fee. Must be >= the quoted fee\\n(see `relayer_fee_in_native`). Surplus is credited to\\n`Withdrawable(native_token)` for the admin to sweep \\xe2\\x80\\x94 mirrors\\nEVM's `msg.value` overpayment going to `withdrawableAmount[ETH_MARKER]`.",
          "name": "gas_amount",
          "type_": "u128"
        },
        {
          "doc": "Free-form 32-byte metadata propagated to the `TokenSent` event.",
          "name": "metadata",
          "type_": {
            "bytes_n": {
              "n": 32
            }
          }
        },
        {
          "doc": "Minimum acceptable swap output on the source chain when\\n`source_token != intermediary_token`.",
          "name": "min_swap_amount",
          "type_": "i128"
        },
        {
          "doc": "Address of the token paid in by the caller.",
          "name": "source_token",
          "type_": "address"
        },
        {
          "doc": "Registered swap adapter used when `source_token != intermediary_token`.",
          "name": "swap_addr",
          "type_": "address"
        },
        {
          "doc": "Registered token-messenger adapter used to bridge the intermediary.",
          "name": "token_messenger_addr",
          "type_": "address"
        }
      ]
    }
  },
  {
    "udt_enum_v0": {
      "doc": "Whether a remote destination token is recognised by the router, and\\nwhether the router should run a destination-side swap for it.",
