  {
    "function_v0": {
      "doc": "I-01: deployment-time constructor. Runs atomically with contract\\ncreation, closing the deploy-init race window. Treasury is mutable\\npost-deploy via L-05 propose_treasury / execute_treasury_rotation;\\nburn pool and SAC ID remain immutable (no setters).\\n\\nL-03: caps for treasury_send and burn_from_pool are admin-configurable\\nat deploy time and via setters. Per-tx cap is a hard ceiling on any\\nsingle call; daily cap rolls over at UTC midnight.",
      "name": "__constructor",
      "inputs": [
        {
          "doc": "",
          "name": "admin",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "ops",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "treasury",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "burn_pool",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "sac_contract_id",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "allowed_hot_wallets",
          "type_": {
            "vec": {
              "element_type": "address"
            }
          }
        },
        {
          "doc": "",
          "name": "treasury_send_max_per_tx",
          "type_": "i128"
        },
        {
          "doc": "",
          "name": "treasury_send_daily_cap",
          "type_": "i128"
        },
        {
          "doc": "",
          "name": "burn_max_per_tx",
          "type_": "i128"
        },
        {
          "doc": "",
          "name": "burn_daily_cap",
          "type_": "i128"
        }
      ],
      "outputs": []
    }
  },
