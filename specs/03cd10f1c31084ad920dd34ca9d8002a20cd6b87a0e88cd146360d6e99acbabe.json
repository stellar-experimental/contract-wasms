    "function_v0": {
      "doc": "I3: Pause OPS flows (treasury_send, burn_from_pool) \\xe2\\x80\\x94 admin only.\\nAdmin governance ops (caps, allowlist, role rotation, upgrades) remain\\navailable so the admin can remediate and unpause. This is the on-chain\\nbrake for an OPS-key compromise; the admin multisig is uncompromised in\\nthat scenario and can halt fund movement without touching SAC allowances.",
      "name": "pause",
      "inputs": [],
      "outputs": []
    }
