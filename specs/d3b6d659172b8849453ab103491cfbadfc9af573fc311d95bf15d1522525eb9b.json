    "function_v0": {
      "doc": "Approve multiple tokens in ONE transaction!\\nWrapper function that calls approve() on multiple token contracts\\n\\nUser signs ONCE, and all tokens are approved for spending by this contract\\n\\nParameters:\\n- owner: User authorizing the approvals\\n- tokens: Vector of token contract addresses\\n- amounts: Vector of amounts to approve (must match tokens length)\\n- expiration_ledger: When the approvals expire",
      "name": "approve_multiple_tokens",
      "inputs": [
        {
          "doc": "",
          "name": "owner",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "tokens",
          "type_": {
            "vec": {
              "element_type": "address"
            }
          }
        },
        {
          "doc": "",
          "name": "amounts",
          "type_": {
            "vec": {
              "element_type": "i128"
            }
          }
        },
        {
          "doc": "",
