              }
            }
          }
        }
      ]
    }
  },
  {
    "function_v0": {
      "doc": "Deposit using pre-approved allowance (AVOIDS Blockaid warnings!)\\nManager can initiate deposit on behalf of user who has approved spending\\n\\nThis is the KEY function to avoid wallet signer modifications!\\nUser calls approve_spending() once, then manager can deposit anytime\\n\\nParameters:\\n- manager: Authorized manager initiating the deposit\\n- from: User whose tokens are being deposited (must have approved allowance)\\n- denomination: Which fixed amount pool\\n- token: Token contract address\\n- commitment: Hash commitment for privacy",
      "name": "deposit_from_allowance",
      "inputs": [
        {
          "doc": "",
          "name": "manager",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "from",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "denomination",
          "type_": {
            "udt": {
              "name": "Denomination"
            }
          }
        },
        {
          "doc": "",
          "name": "token",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "commitment",
          "type_": {
            "bytes_n": {
              "n": 32
            }
          }
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": "u32",
            "error_type": {
              "udt": {
                "name": "ContractError"
              }
            }
          }
        }
      ]
    }
  },
