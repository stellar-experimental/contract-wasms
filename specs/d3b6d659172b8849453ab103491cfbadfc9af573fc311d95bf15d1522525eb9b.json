          "type_": "u32"
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": {
              "tuple": {
                "value_types": []
              }
            },
            "error_type": {
              "udt": {
                "name": "ContractError"
              }
            }
          }
        }
      ]
    }
  },
  {
    "function_v0": {
      "doc": "Register that user has approved spending (for tracking only)\\n\\xe2\\x9a\\xa0\\xef\\xb8\\x8f USER MUST FIRST APPROVE TOKEN CONTRACT DIRECTLY!\\n\\nStep 1 (User does this): Call token contract's approve() directly:\\ntoken.approve(from: user, spender: THIS_CONTRACT, amount: X, expiration: ledger+200000)\\n\\nStep 2 (User does this): Call this function to register the approval\\n\\nThis just tracks the allowance - actual approval happens at token level",
      "name": "register_approval",
      "inputs": [
        {
          "doc": "",
          "name": "owner",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "token",
          "type_": "address"
