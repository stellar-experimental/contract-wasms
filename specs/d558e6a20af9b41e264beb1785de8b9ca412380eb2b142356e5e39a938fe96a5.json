  {
    "function_v0": {
      "doc": "Transfers ownership immediately to a new address.\\n\\nUse with caution - if you transfer to a wrong address, ownership is lost forever.\\nConsider using `begin_ownership_transfer` instead.\\n\\n# Panics\\n- `OwnerNotSet` if no owner is currently set\\n- `TransferInProgress` if a 2-step transfer is in progress",
      "name": "transfer_ownership",
      "inputs": [
        {
          "doc": "",
          "name": "new_owner",
          "type_": "address"
        }
      ],
      "outputs": []
    }
  },
  {
    "function_v0": {
      "doc": "Begins an ownership transfer to a new address.\\n\\nThe new owner must call `accept_ownership()` within `ttl` ledgers\\nto complete the transfer. The pending transfer will automatically expire after.\\n\\n# Arguments\\n- `new_owner` - The proposed new owner\\n- `ttl` - Number of ledgers the new owner has to accept.\\nUse `0` to cancel a pending transfer (new_owner must match pending).\\n\\n# Panics\\n- `OwnerNotSet` if no owner is currently set\\n- `NoPendingTransfer` when cancelling and no pending transfer exists\\n- `InvalidTtl` if ttl exceeds max TTL\\n- `InvalidPendingOwner` when cancelling with wrong new_owner address",
      "name": "begin_ownership_transfer",
      "inputs": [
        {
          "doc": "",
          "name": "new_owner",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "ttl",
          "type_": "u32"
        }
      ],
      "outputs": []
    }
  },
  {
    "function_v0": {
      "doc": "Accepts a pending 2-step ownership transfer.\\n\\nMust be called by the pending owner before the TTL expires.\\n\\n# Panics\\n- `NoPendingTransfer` if there is no pending transfer (or it expired)",
      "name": "accept_ownership",
      "inputs": [],
      "outputs": []
    }
  },
  {
    "function_v0": {
      "doc": "Permanently renounces ownership.\\n\\n# Panics\\n- `OwnerNotSet` if no owner is currently set\\n- `TransferInProgress` if a 2-step transfer is in progress (cancel it first)",
      "name": "renounce_ownership",
      "inputs": [],
      "outputs": []
    }
  },
  {
    "function_v0": {
      "doc": "Extends the instance TTL.\\n\\n# Arguments\\n\\n* `threshold` - The threshold to extend the TTL (if current TTL is below this, extend).\\n* `extend_to` - The TTL to extend to.",
