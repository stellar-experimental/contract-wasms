    "function_v0": {
      "doc": "Execute one Soroswap swap along `path` on behalf of `user`.\\n\\nFlow:\\n1. user authorizes this invocation\\n2. pull `amount_in` of `token_in` from user into this contract\\n3. swap via the Soroswap router (proceeds land on this contract)\\n4. enforce `amount_out_min` on the output\\n5. forward the proceeds to `user`\\n\\nReturns the amount of `token_out` delivered.",
      "name": "swap_soroswap",
      "inputs": [
        {
          "doc": "",
          "name": "user",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "soroswap_router",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "token_in",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "token_out",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "amount_in",
          "type_": "i128"
        },
        {
          "doc": "",
          "name": "amount_out_min",
          "type_": "i128"
        },
        {
          "doc": "",
          "name": "path",
          "type_": {
            "vec": {
              "element_type": "address"
            }
          }
        },
        {
          "doc": "",
          "name": "deadline",
          "type_": "u64"
        }
      ],
      "outputs": [
        "i128"
      ]
    }
  }
