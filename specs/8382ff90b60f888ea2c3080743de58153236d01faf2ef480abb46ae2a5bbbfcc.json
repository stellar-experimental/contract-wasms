    "udt_struct_v0": {
      "doc": "`SEP-40` compliant oracle contract's configuration",
      "lib": "",
      "name": "OracleConfig",
      "fields": [
        {
          "doc": "Oracle contract's address on the ledger",
          "name": "address",
