    "function_v0": {
      "doc": "Idempotently deploys a contract and then dispatches a sequence of inner\\ncontract calls in the same top-level invocation.\\n\\nIf the deterministic address is already deployed, deployment is skipped\\nand the calls run against the existing contract. If any inner call\\nreverts, the host aborts the transaction and the whole sequence\\n(including the deploy) is rolled back.",
      "name": "deploy_and_call",
      "inputs": [
        {
          "doc": "",
          "name": "deployment_args",
          "type_": {
            "udt": {
              "name": "ContractDeploymentArgs"
            }
          }
        },
        {
          "doc": "",
          "name": "calls",
          "type_": {
            "vec": {
              "element_type": {
                "udt": {
                  "name": "ContractCall"
                }
              }
            }
          }
        }
      ],
      "outputs": [
        "address"
      ]
    }
  },
  {
    "function_v0": {
