    "function_v0": {
      "doc": "Get all position values for an account across all registered Blend pools.\\n\\nCalled by PositionRegistry as:\\n`adapter.get_all_pos(account, oracle_registry, accounting_token, enabled_position_ids)`\\n\\n`enabled_position_ids` \\xe2\\x80\\x94 the set of position IDs that are enabled in the registry for\\nthis account/protocol. Each pool at index `i` has position_id Symbol `INDEX_STRS[i]`.\\n\\nPer-pool error isolation: if any pool call fails, that pool is skipped (try_invoke).",
      "name": "get_all_pos",
      "inputs": [
        {
          "doc": "",
          "name": "account",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "oracle_registry",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "accounting_token",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "enabled_position_ids",
          "type_": {
            "vec": {
              "element_type": "symbol"
            }
          }
        }
      ],
      "outputs": [
        {
          "vec": {
            "element_type": {
              "udt": {
                "name": "PositionValue"
              }
            }
          }
        }
      ]
    }
