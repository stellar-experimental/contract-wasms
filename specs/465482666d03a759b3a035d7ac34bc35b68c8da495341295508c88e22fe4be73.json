  {
    "function_v0": {
      "doc": "Withdraw accumulated platform yield from Blend (admin only)\\nExtracts all remaining Blend collateral (fees + accrued interest)\\nand transfers to the specified recipient.\\n\\nThis should only be called after settle() has paid the seller,\\nso the remaining Blend position is pure platform revenue.",
      "name": "withdraw_yield",
      "inputs": [
