    "function_v0": {
      "doc": "Initialize the pool contract\\n\\n# Arguments\\n* `admin` - Address authorized to trigger settlements\\n* `seller` - Address that receives settlement payouts\\n* `fee_percent` - Fee percentage in basis points (200 = 2%)\\n* `usdc_token` - USDC token contract address",
      "name": "initialize",
      "inputs": [
        {
          "doc": "",
          "name": "admin",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "seller",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "fee_percent",
          "type_": "u32"
        },
        {
          "doc": "",
          "name": "usdc_token",
          "type_": "address"
        }
      ],
      "outputs": []
    }
  },
