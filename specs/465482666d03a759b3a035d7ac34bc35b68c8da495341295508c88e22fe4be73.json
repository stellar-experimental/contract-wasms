  {
    "function_v0": {
      "doc": "Withdraw collateral from Blend pool back to contract (admin only)\\nUses Blend SDK request_type 3 (WithdrawCollateral)\\n\\n# Arguments\\n* `amount_usdc` - Amount of Blend USDC to withdraw (stroops). Use i128::MAX for all.\\n* `amount_xlm` - Amount of XLM to withdraw (stroops). Use i128::MAX for all.",
      "name": "withdraw_from_blend",
      "inputs": [
        {
          "doc": "",
          "name": "amount_usdc",
          "type_": "i128"
        },
        {
          "doc": "",
          "name": "amount_xlm",
          "type_": "i128"
        }
      ],
      "outputs": []
    }
  },
  {
    "function_v0": {
      "doc": "Settle deposits to seller \\xe2\\x80\\x94 only the product price is withdrawn.\\nFees (1% buyer + 1% seller = FeePercent) and all accrued yield\\nstay in the Blend pool, compounding until withdrawn via withdraw_yield.\\n\\nFormula: seller_payout = total_deposits \\xc3\\x97 (10000 - half_fee) / (10000 + half_fee)\\nwhere half_fee = FeePercent / 2 (each side's share)\\n\\nExample (FeePercent=200, deposit=$10.10):\\nseller = 10.10 \\xc3\\x97 9900 / 10100 = $9.90\\n$0.20 (2% of product price) stays in Blend + yield",
      "name": "settle",
      "inputs": [],
      "outputs": [
        {
          "tuple": {
            "value_types": [
              "i128",
              "i128"
            ]
          }
        }
      ]
    }
  },
  {
    "function_v0": {
      "doc": "Get current pool status\\nReturns (total_deposits_usdc, total_deposits_xlm, supplied_to_blend)",
