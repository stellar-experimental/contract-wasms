  {
    "udt_union_v0": {
      "doc": "Where in the flow the affiliate fee is collected.\\n\\n- `Input`:  fee charged from `input_token` *before* any instruction runs.\\n- `Output`: fee charged from `output_token` *after* all instructions run.",
      "lib": "",
      "name": "FeePosition",
