          "type_": "address"
        },
        {
          "doc": "",
          "name": "function",
          "type_": "symbol"
        }
      ]
    }
  },
  {
    "udt_struct_v0": {
      "doc": "",
      "lib": "",
      "name": "AffiliateFee",
      "fields": [
