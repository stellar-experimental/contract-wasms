  {
    "function_v0": {
      "doc": "v2 \\xe2\\x80\\x94 CUSTODIAL routing. The router pulls `input_amount` of `input_token`\\nfrom `user`, runs each step on the held funds (using\\n`authorize_as_current_contract` to authorize what each target pulls from\\nthe router), optionally takes intermediate fees from any token the router\\nholds mid-route, and finally sends the residual `output_token` (and any\\nremaining `input_token`) to `user`.\\n\\nReturns: the user's final received amount of `output_token`, NET of any\\noutput-side fee.\\n\\nUse this entry point when:\\n- Another contract is calling the router (source-account auth doesn't\\napply; the calling contract authorizes only the initial pull).\\n- You need a fee from an intermediate token (e.g. swap A\\xe2\\x86\\x92B, fee in B,\\nbridge B).\\n- Sponsored / fee-bumped flows where `user` is not the tx source.",
      "name": "route",
      "inputs": [
        {
          "doc": "",
          "name": "user",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "swap_id",
          "type_": {
            "bytes_n": {
              "n": 16
            }
          }
        },
        {
          "doc": "",
          "name": "input_token",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "input_amount",
          "type_": "u128"
        },
        {
          "doc": "",
          "name": "output_token",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "steps",
          "type_": {
            "vec": {
              "element_type": {
                "udt": {
                  "name": "RouteStep"
                }
              }
            }
          }
        },
        {
          "doc": "",
          "name": "affiliate_fees",
          "type_": {
            "vec": {
              "element_type": {
                "udt": {
                  "name": "AffiliateFee"
                }
              }
            }
          }
        },
        {
          "doc": "",
          "name": "fee_position",
          "type_": {
            "udt": {
              "name": "FeePosition"
            }
          }
        },
        {
          "doc": "",
          "name": "intermediate_fees",
          "type_": {
            "vec": {
              "element_type": {
                "udt": {
                  "name": "IntermediateFee"
                }
              }
            }
          }
        }
      ],
      "outputs": [
        "u128"
      ]
    }
  },
  {
    "function_v0": {
      "doc": "Aggregate multiple contract calls in a single tx, with affiliate fees\\ntaken either from the input token (before instructions) or from the\\noutput token (after instructions), per `fee_position`.\\n\\nReturns the user's actual output_token amount NET of any output-side fee.\\n\\nPermissionless: there is no allowlist of targets. The user signs a tx\\nthat contains the exact `instructions` vector being authorized; their\\nsignature *is* the authorization. The router does not custody funds and\\ncannot move tokens beyond what the user has signed for (directly or via\\nsource-account auth).",
      "name": "execute",
      "inputs": [
        {
          "doc": "",
          "name": "user",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "swap_id",
          "type_": {
            "bytes_n": {
              "n": 16
            }
          }
        },
        {
          "doc": "",
          "name": "input_token",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "input_amount",
          "type_": "u128"
        },
        {
          "doc": "",
          "name": "output_token",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "instructions",
          "type_": {
            "vec": {
              "element_type": {
                "udt": {
                  "name": "Instruction"
                }
              }
            }
          }
        },
        {
          "doc": "",
          "name": "affiliate_fees",
          "type_": {
            "vec": {
              "element_type": {
                "udt": {
                  "name": "AffiliateFee"
                }
              }
            }
          }
        },
        {
          "doc": "",
          "name": "fee_position",
          "type_": {
            "udt": {
              "name": "FeePosition"
            }
          }
        }
      ],
      "outputs": [
        "u128"
      ]
    }
  },
  {
    "udt_struct_v0": {
      "doc": "One sub-invocation the router pre-authorizes via `authorize_as_current_contract`\\nbefore invoking a `RouteStep`. Use for transfers that the *target* will trigger\\nfrom the router as `from` (e.g. `token.transfer(router, pool, amount)` inside\\nAquarius). Top-level transfers the router does itself (e.g. paying out fees)\\ndon't need a declaration \\xe2\\x80\\x94 they're auto-authorized as the immediate caller.",
      "lib": "",
      "name": "AuthDeclaration",
      "fields": [
