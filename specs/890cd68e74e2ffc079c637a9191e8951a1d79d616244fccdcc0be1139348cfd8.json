    "function_v0": {
      "doc": "Commit and reveal in a single transaction\\n\\nThis is an optimization for the second player to commit - since the other\\nplayer has already committed, there's no advantage to hiding your allocation.\\nThis also auto-resolves the game if the first player has already revealed.\\n\\nReturns Option<Address> - Some(winner) if game was auto-resolved, None if waiting for opponent's reveal",
      "name": "commit_and_reveal",
      "inputs": [
        {
          "doc": "",
          "name": "session_id",
          "type_": "u32"
        },
        {
          "doc": "",
          "name": "player",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "allocation",
