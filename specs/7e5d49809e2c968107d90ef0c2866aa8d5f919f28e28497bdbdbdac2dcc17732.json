    "function_v0": {
      "doc": "Register a new user account via a specific relay. Auto-assigns an account number.\\nReturns the assigned account number.\\n\\nFails if the UUID is already registered (duplicate). The relay handles\\nre-registration by detecting existing accounts and recreating groups.\\n\\nAuthenticated by TEE signature over (uuid_bytes).",
      "name": "register",
      "inputs": [
        {
          "doc": "",
          "name": "signal_username",
          "type_": "string"
        },
        {
          "doc": "",
          "name": "uuid",
          "type_": "string"
        },
        {
          "doc": "",
          "name": "stellar_address",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "tee_signature",
          "type_": {
            "bytes_n": {
              "n": 64
            }
          }
