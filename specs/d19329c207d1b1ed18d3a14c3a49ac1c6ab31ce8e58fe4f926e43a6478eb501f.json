    "udt_error_enum_v0": {
      "doc": "Custom error types for the escrow contract",
      "lib": "",
      "name": "EscrowError",
      "cases": [
        {
          "doc": "Contract is already initialized",
          "name": "AlreadyInitialized",
          "value": 1
        },
        {
          "doc": "Contract configuration not found",
          "name": "ConfigNotInitialized",
          "value": 2
        },
        {
          "doc": "Unauthorized access",
          "name": "Unauthorized",
          "value": 3
        },
        {
          "doc": "Escrow not found",
          "name": "EscrowNotFound",
          "value": 4
        },
        {
          "doc": "Invalid amount (must be greater than 0)",
          "name": "InvalidAmount",
          "value": 5
        },
        {
          "doc": "Invalid fee basis points (must be 0-10000)",
          "name": "InvalidFeeBps",
          "value": 6
        },
        {
          "doc": "Invalid guarantee days (must be 1-36500)",
          "name": "InvalidGuaranteeDays",
          "value": 7
        },
        {
          "doc": "Invalid product ID (cannot be empty)",
          "name": "InvalidProductId",
          "value": 8
        },
        {
          "doc": "Escrow is not in active status",
          "name": "EscrowNotActive",
          "value": 9
        },
        {
          "doc": "Guarantee period not expired",
          "name": "GuaranteePeriodNotExpired",
          "value": 10
        },
        {
          "doc": "Guarantee period already expired",
          "name": "GuaranteePeriodExpired",
          "value": 11
        },
        {
          "doc": "Fee amount exceeds escrow amount",
          "name": "FeeExceedsAmount",
          "value": 12
        },
        {
          "doc": "Invalid signature for meta-transaction",
          "name": "InvalidSignature",
          "value": 13
        },
        {
          "doc": "Nonce mismatch - replay attack detected",
          "name": "InvalidNonce",
          "value": 14
        },
        {
          "doc": "Signature expired",
          "name": "SignatureExpired",
          "value": 15
        },
        {
          "doc": "Invalid function selector for meta-transaction",
          "name": "InvalidFunctionSelector",
          "value": 16
        },
        {
          "doc": "Counter overflow (too many escrows)",
          "name": "CounterOverflow",
          "value": 17
        },
        {
          "doc": "Token not in allowed list",
          "name": "TokenNotAllowed",
          "value": 18
        },
        {
          "doc": "Escrow is not in disputed status",
          "name": "NotDisputed",
          "value": 19
        },
        {
          "doc": "Escrow is already disputed",
          "name": "AlreadyDisputed",
          "value": 20
        },
        {
          "doc": "No dispute to resolve (no proposals exist)",
          "name": "NoDisputeToResolve",
          "value": 21
        },
        {
          "doc": "Dispute already resolved",
          "name": "DisputeAlreadyResolved",
          "value": 22
        },
        {
          "doc": "Both parties must agree on resolution",
          "name": "BothPartiesMustAgree",
          "value": 23
        },
        {
          "doc": "Party has already proposed resolution",
          "name": "AlreadyProposed",
          "value": 24
        }
      ]
    }
