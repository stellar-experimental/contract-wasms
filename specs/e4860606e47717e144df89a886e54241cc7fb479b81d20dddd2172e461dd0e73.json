  {
    "function_v0": {
      "doc": "Return the compact proxy view used by clients and tests.\\n\\n`maxWithdraw` and `maxRedeem` values in the preview tuple are bounded by\\ncurrent idle assets and return zero when the vault is non-idle or paused.\\nThis is intentional: Soroban `withdraw` / `redeem` are atomic idle exits,\\nwhile market-backed exits must use `request_withdraw` and allocator-driven\\nqueue execution.",
      "name": "proxy_view",
      "inputs": [
        {
          "doc": "",
          "name": "owner",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "assets",
          "type_": "i128"
        },
        {
          "doc": "",
          "name": "shares",
          "type_": "i128"
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": {
              "tuple": {
                "value_types": [
                  {
                    "tuple": {
                      "value_types": [
                        {
                          "tuple": {
                            "value_types": [
                              "address",
                              "address",
                              "address",
                              "address"
                            ]
                          }
                        },
                        {
                          "tuple": {
                            "value_types": [
                              "i128",
                              "i128",
                              "bool"
                            ]
                          }
                        },
                        {
                          "tuple": {
                            "value_types": [
                              "i128",
                              "i128",
                              "i128",
                              "i128"
                            ]
                          }
                        },
                        {
                          "tuple": {
                            "value_types": [
                              "i128",
                              "u64",
                              "i128",
                              "i128",
                              "i128"
                            ]
                          }
                        }
                      ]
                    }
                  },
                  {
                    "tuple": {
                      "value_types": [
                        {
                          "vec": {
                            "element_type": "u32"
                          }
                        },
                        {
                          "vec": {
                            "element_type": {
                              "tuple": {
                                "value_types": [
                                  "string",
                                  "i128",
                                  "i128"
                                ]
                              }
                            }
                          }
                        }
                      ]
                    }
                  },
                  {
                    "tuple": {
                      "value_types": [
                        "i128",
                        "i128",
                        "i128",
                        "i128",
                        "i128",
                        "i128",
                        "i128",
                        "i128"
                      ]
                    }
                  }
                ]
              }
            },
            "error_type": {
              "udt": {
                "name": "ContractError"
              }
            }
          }
        }
      ]
