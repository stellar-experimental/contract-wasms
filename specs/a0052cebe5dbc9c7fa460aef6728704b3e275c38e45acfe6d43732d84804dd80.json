[
  {
    "udt_struct_v0": {
      "doc": "One hop in a circular route. Each hop uses one protocol.\\nFor multi-hop paths on the same protocol, use a longer path vector.\\n\\nExamples:\\nSoroswap single: { protocol: 0, path: [XLM, USDC], pool_hashes: [], pools: [] }\\nSoroswap multi:  { protocol: 0, path: [XLM, USDC, AQUA], pool_hashes: [], pools: [] }\\nAqua single:     { protocol: 1, path: [USDC, XLM], pool_hashes: [hash], pools: [] }\\nAqua multi:      { protocol: 1, path: [A, B, C], pool_hashes: [h1, h2], pools: [] }\\nPhoenix single:  { protocol: 2, path: [XLM, PHO], pool_hashes: [], pools: [pool_addr] }",
      "lib": "",
      "name": "Hop",
      "fields": [
        {
          "doc": "Token path for this hop. First = input, last = output.",
          "name": "path",
          "type_": {
            "vec": {
              "element_type": "address"
            }
          }
        },
        {
          "doc": "Aqua: pool hash per pair (len = path.len - 1). Empty for other protocols.",
          "name": "pool_hashes",
          "type_": {
            "vec": {
              "element_type": {
                "bytes_n": {
                  "n": 32
                }
              }
            }
          }
        },
        {
          "doc": "Phoenix: pool address per pair (len = path.len - 1). Empty for other protocols.",
          "name": "pools",
          "type_": {
            "vec": {
              "element_type": "address"
            }
          }
        },
        {
          "doc": "Protocol: 0=Soroswap, 1=Aqua, 2=Phoenix",
          "name": "protocol",
          "type_": "u32"
        }
      ]
    }
  },
