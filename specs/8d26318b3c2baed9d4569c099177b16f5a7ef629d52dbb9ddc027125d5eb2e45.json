  {
    "udt_struct_v0": {
      "doc": "Pending administrator under the two-step admin transfer flow:\\nthe existing admin nominates a successor with `propose`, and the\\nsuccessor finalises the swap with `accept` from their own auth context.",
      "lib": "",
      "name": "PendingAdmin",
