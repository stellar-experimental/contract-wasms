  {
    "udt_error_enum_v0": {
      "doc": "",
      "lib": "",
      "name": "FactoryError",
      "cases": [
        {
          "doc": "accept_admin called but no nomination is pending.",
          "name": "NoPendingAdmin",
          "value": 1
        },
        {
          "doc": "Fee amount is negative.",
          "name": "InvalidFeeAmount",
          "value": 2
        },
        {
          "doc": "Fee amount exceeds MAX_FEE_AMOUNT.",
          "name": "FeeOutOfBounds",
          "value": 3
        },
        {
          "doc": "Fee amount is below the configured MinFee.",
          "name": "FeeBelowMin",
          "value": 4
        },
        {
          "doc": "set_fee_enabled(true) called before token+dest+standard were set.",
          "name": "FeeNotConfigured",
          "value": 5
        },
        {
          "doc": "Custom fee expiry timestamp is not in the future.",
          "name": "ExpiryInPast",
          "value": 6
        },
        {
          "doc": "VaultMeta is missing (constructor never ran or state lost).",
          "name": "NotInitialized",
          "value": 7
        }
      ]
    }
  },
