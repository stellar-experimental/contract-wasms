  {
    "function_v0": {
      "doc": "Execute a payment for a subscription. CRITICAL FUNCTION.\\n\\n# Security: Checks-Effects-Interactions Pattern\\n1. Load and validate subscription (CHECKS)\\n2. Verify payment is due, status is valid\\n3. Check authorization via Authorization Manager\\n4. Update state BEFORE transfer (EFFECTS)\\n5. Execute token transfer (INTERACTIONS)\\n6. Record payment in Authorization Manager\\n\\n# Idempotency\\nUses (subscription_id, payment_number) to prevent double execution",
      "name": "execute_payment",
      "inputs": [
        {
          "doc": "",
          "name": "subscription_id",
          "type_": "string"
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": {
              "udt": {
                "name": "PaymentExecutedEvent"
              }
            },
            "error_type": {
              "udt": {
                "name": "PaymentError"
              }
            }
          }
        }
      ]
    }
  },
