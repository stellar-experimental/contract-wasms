    "function_v0": {
      "doc": "Return the full escrowed amount to the user.\\n\\nAuthorization rules:\\n- The **relayer** may refund at any time.\\n- The **user** may self-refund only after the order has expired.\\n\\nA `caller` parameter is required because Soroban has no implicit\\n`msg.sender`; we verify `caller.require_auth()` and then check\\nwhether the caller is the relayer or the order's user.",
      "name": "refund_order",
      "inputs": [
        {
          "doc": "",
          "name": "order_id",
          "type_": "bytes"
        },
        {
          "doc": "",
