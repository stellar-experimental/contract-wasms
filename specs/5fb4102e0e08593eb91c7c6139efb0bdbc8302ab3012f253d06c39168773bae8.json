    "function_v0": {
      "doc": "Return the full `Order` struct for the given id (or error).\\n\\n**TTL note:** Read-only queries intentionally do not bump the\\npersistent entry's TTL.  If the order is near expiry in ledger\\nstorage, a write operation (release / refund / cancel) will bump it.\\nFrontends that need guaranteed availability should call a write path\\nor use `extend_ttl` via a separate admin utility.",
      "name": "get_order",
      "inputs": [
        {
          "doc": "",
          "name": "order_id",
          "type_": "bytes"
