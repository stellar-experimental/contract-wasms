  {
    "udt_struct_v0": {
      "doc": "Groth16 Verification Key\\n\\nGenerated by the trusted setup, contains the public parameters\\nneeded to verify proofs for a specific circuit.",
      "lib": "",
      "name": "VerificationKey",
      "fields": [
        {
          "doc": "alpha * G1",
          "name": "alpha_g1",
          "type_": {
            "bytes_n": {
              "n": 64
            }
          }
        },
        {
          "doc": "beta * G2",
