  {
    "function_v0": {
      "doc": "Configure the adapter.\\n\\nThe `custodian` may be either an account or contract address. It is the\\noperational address that receives allocated funds and is expected to\\nreturn assets to this adapter before vault withdrawals are progressed.",
      "name": "__constructor",
      "inputs": [
        {
          "doc": "",
          "name": "admin",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "vault",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "custodian",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "asset",
          "type_": "address"
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": "void",
            "error_type": {
              "udt": {
                "name": "AdapterError"
              }
            }
          }
        }
      ]
    }
  },
  {
    "function_v0": {
      "doc": "Pause or unpause new vault allocation and reported-NAV update operations.\\n\\nWhile paused, vault and custodian report updates are blocked. The admin\\nmay still call `set_reported_assets` to correct NAV during recovery.",
      "name": "set_paused",
      "inputs": [
        {
          "doc": "",
          "name": "caller",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "paused",
          "type_": "bool"
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": "void",
            "error_type": {
              "udt": {
                "name": "AdapterError"
              }
            }
          }
        }
      ]
    }
  },
  {
    "function_v0": {
      "doc": "",
      "name": "paused",
      "inputs": [],
      "outputs": [
        "bool"
      ]
    }
  },
  {
    "function_v0": {
      "doc": "Forward allocated funds to the configured custodian and increase the\\nadapter's reported route NAV by `amount`.\\n\\nReported route NAV is the amount attributed to this adapter that has not\\nyet been released back to the vault. It includes both offchain position\\nvalue and any returned idle liquidity still held by this adapter.",
      "name": "supply",
      "inputs": [
        {
          "doc": "",
          "name": "caller",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "asset",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "amount",
          "type_": "i128"
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": "void",
            "error_type": {
              "udt": {
                "name": "AdapterError"
              }
            }
          }
        }
      ]
    }
  },
  {
    "function_v0": {
      "doc": "Withdraw exactly `amount` of returned idle liquidity to the vault.\\n\\nThis compatibility method is exact-only because it does not return the\\nrealized amount. Use `progress_withdrawal` when partial settlement is\\nacceptable and the caller can account for the amount actually released.\\nSettlement remains available while paused so already returned liquidity\\ncan be recovered during an incident.",
      "name": "withdraw",
      "inputs": [
        {
          "doc": "",
          "name": "caller",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "asset",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "amount",
          "type_": "i128"
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": "void",
            "error_type": {
              "udt": {
                "name": "AdapterError"
              }
            }
          }
        }
      ]
    }
  },
  {
    "function_v0": {
      "doc": "Progress a vault withdrawal using only assets already returned to this\\nadapter. This method does not initiate any offchain market exit, and\\nremains available while paused so returned liquidity can be recovered.",
      "name": "progress_withdrawal",
      "inputs": [
        {
          "doc": "",
          "name": "caller",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "asset",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "amount",
          "type_": "i128"
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": "i128",
            "error_type": {
              "udt": {
                "name": "AdapterError"
              }
            }
          }
        }
      ]
    }
  },
  {
    "function_v0": {
      "doc": "Return the adapter's reported route NAV for `asset`.\\n\\nReturned idle balance is intentionally not auto-added here because\\nreported route NAV already includes liquidity that has returned to this\\nadapter but has not yet been released to the vault. Operators should use\\n`set_reported_assets` for explicit NAV updates when offchain route value\\nchanges, and should avoid reporting only the offchain remainder while\\nreturned liquidity is still pending on this adapter.",
      "name": "total_assets",
      "inputs": [
        {
          "doc": "",
          "name": "asset",
          "type_": "address"
        }
      ],
      "outputs": [
        "i128"
      ]
    }
  },
  {
    "function_v0": {
      "doc": "Explicitly set reported route NAV for `asset`.\\n\\nThe configured custodian is allowed to report NAV because custody of the\\noffchain position is already part of this adapter's trust boundary. This\\nkeeps reporting usable when the admin is a governance contract. The\\namount must represent total route NAV not yet released to the vault, not\\nonly the offchain remainder when returned idle liquidity is pending.\\n`report_nonce` must be exactly one greater than the current report\\nnonce; every successful NAV mutation advances this same revision.\\n\\nPause blocks vault and custodian reporting, but intentionally leaves an\\nadmin recovery path for emergency NAV correction.",
      "name": "set_reported_assets",
      "inputs": [
        {
          "doc": "",
          "name": "caller",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "asset",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "expected_current",
          "type_": "i128"
        },
        {
          "doc": "",
          "name": "amount",
          "type_": "i128"
        },
        {
          "doc": "",
          "name": "report_nonce",
          "type_": "u64"
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": "void",
            "error_type": {
              "udt": {
                "name": "AdapterError"
              }
            }
          }
        }
      ]
    }
  },
