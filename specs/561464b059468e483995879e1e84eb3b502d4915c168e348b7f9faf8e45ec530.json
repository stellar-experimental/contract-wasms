          "type_": "i128"
        }
      ],
      "outputs": []
    }
  },
  {
    "udt_struct_v0": {
      "doc": "Trade params Receiver needs to service a flash-loan callback.\\nThe Starter passes these into `set_arb_params` before firing flash_loan.\\n\\nFields the Starter owns (blend_pool, amount) are NOT in this struct \\xe2\\x80\\x94 the\\nReceiver does not need them; Blend supplies the loan amount as exec_op's\\n`amount` arg.",
      "lib": "",
      "name": "ArbParams",
      "fields": [
