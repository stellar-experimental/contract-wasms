  {
    "function_v0": {
      "doc": "Admin calls this once payer payment is detected in the lockbox.\\nDistributes USDC from the contract's own balance:\\ncollected >= advance_amount \\xe2\\x86\\x92 repay advance to funder, reserve to msme\\ncollected < advance_amount  \\xe2\\x86\\x92 send all to funder, log shortfall (leakage path)",
      "name": "settle",
      "inputs": [
        {
          "doc": "",
          "name": "admin",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "invoice_id",
          "type_": "string"
        },
        {
          "doc": "",
          "name": "collected_amount",
          "type_": "i128"
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": {
              "udt": {
                "name": "LockboxRecord"
              }
            },
            "error_type": "error"
          }
        }
      ]
    }
