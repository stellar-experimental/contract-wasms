    "function_v0": {
      "doc": "Start a new game between two players with points.\\nThis creates a session in the Game Hub and locks points before starting the game.\\n\\n**CRITICAL:** This method requires authorization from THIS contract (not players).\\nThe Game Hub will call `game_id.require_auth()` which checks this contract's address.\\n\\n# Arguments\\n* `session_id` - Unique session identifier (u32)\\n* `player1` - Address of first player\\n* `player2` - Address of second player\\n* `player1_points` - Points amount committed by player 1\\n* `player2_points` - Points amount committed by player 2",
      "name": "start_game",
      "inputs": [
        {
          "doc": "",
          "name": "session_id",
          "type_": "u32"
        },
        {
          "doc": "",
          "name": "player1",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "player2",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "player1_points",
          "type_": "i128"
        },
        {
          "doc": "",
          "name": "player2_points",
          "type_": "i128"
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": "void",
            "error_type": "error"
          }
        }
      ]
    }
  },
