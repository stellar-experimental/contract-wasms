  {
    "function_v0": {
      "doc": "Idempotently deploys a contract and then dispatches a sequence of inner\\ncontract calls in the same top-level invocation.\\n\\nIf the deterministic address is already deployed, deployment is skipped\\nand the calls run against the existing contract. If any inner call\\nreverts, the host aborts the transaction and the whole sequence\\n(including the deploy) is rolled back.\\n\\nThe deployed contract's authorization requirement is hoisted to the\\ntop-level invocation via `require_auth`. Without this, sub-invocations\\nthat internally call `require_auth(self)` \\xe2\\x80\\x94 such as a smart-account's\\n`add_signer` \\xe2\\x80\\x94 would fail with `Error(Auth, InvalidAction)` because\\ntheir auth wouldn't be tied to the root contract invocation. Hoisting\\nhere means callers sign for the deployed contract once and the\\nsignature transitively covers any inner self-authorizing calls.",
      "name": "deploy_and_call",
      "inputs": [
        {
          "doc": "",
          "name": "deployment_args",
          "type_": {
            "udt": {
              "name": "ContractDeploymentArgs"
            }
          }
        },
        {
          "doc": "",
          "name": "calls",
          "type_": {
            "vec": {
              "element_type": {
                "udt": {
                  "name": "ContractCall"
                }
              }
            }
          }
        }
      ],
      "outputs": [
        "address"
      ]
    }
  },
  {
    "function_v0": {
      "doc": "Deploys a contract on behalf of the `ContractFactory` contract.\\nIf the contract is already deployed at the deterministic address, returns it.",
