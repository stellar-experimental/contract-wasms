    "function_v0": {
      "doc": "Initialize the factory with the oracle WASM hash.\\n\\n# Arguments\\n* `owner` - The owner address that can update the WASM hash\\n* `upgrader` - The upgrader address that can upgrade the factory\\n* `oracle_wasm_hash` - The WASM hash of the oracle contract to deploy\\n\\n# Errors\\n* `AlreadyInitialized` - Factory has already been initialized",
      "name": "initialize",
      "inputs": [
        {
          "doc": "",
          "name": "owner",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "upgrader",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "oracle_wasm_hash",
          "type_": {
            "bytes_n": {
              "n": 32
            }
          }
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": {
              "tuple": {
                "value_types": []
              }
            },
            "error_type": {
