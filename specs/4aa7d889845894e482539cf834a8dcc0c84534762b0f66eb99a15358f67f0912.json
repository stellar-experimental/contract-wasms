    "function_v0": {
      "doc": "Set a new upgrader address. Only callable by the current upgrader.\\n\\nThe upgrader role is independent from ownership \\xe2\\x80\\x94 the owner cannot\\nchange the upgrader, and the upgrader cannot perform owner actions.\\n\\n# Errors\\n* `NotInitialized` - Factory has not been initialized\\n* `NoUpgraderSet` - No upgrader has been set\\n* `Unauthorized` - Caller is not the current upgrader",
      "name": "set_upgrader",
      "inputs": [
        {
          "doc": "",
          "name": "new_upgrader",
          "type_": "address"
        }
      ],
      "outputs": [
        {
