              "tuple": {
                "value_types": []
              }
            },
            "error_type": {
              "udt": {
                "name": "FactoryError"
              }
            }
          }
        }
      ]
    }
  },
  {
    "function_v0": {
      "doc": "Deploy a new oracle contract.\\n\\nThe salt is derived on-chain from the oracle parameters, so\\neach parameter tuple has a canonical address.\\n\\n# Arguments\\n* `oracle_owner` - The owner of the new oracle\\n* `pt` - The PT token address being priced\\n* `maturity` - The maturity timestamp\\n* `initial_implied_apy` - The initial implied APY (18 decimals)\\n* `future_pt_value` - The future PT value at maturity\\n* `decimals` - The decimals for the price output\\n\\nReturns the address of the newly deployed oracle.\\n\\n# Errors\\n* `NotInitialized` - Factory has not been initialized",
      "name": "deploy_oracle",
      "inputs": [
        {
          "doc": "",
          "name": "oracle_owner",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "pt",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "maturity",
          "type_": "u64"
        },
        {
          "doc": "",
          "name": "initial_implied_apy",
          "type_": "i128"
        },
        {
          "doc": "",
          "name": "future_pt_value",
          "type_": "i128"
        },
        {
          "doc": "",
          "name": "decimals",
          "type_": "u32"
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": "address",
            "error_type": {
              "udt": {
                "name": "FactoryError"
              }
            }
          }
        }
      ]
    }
  },
