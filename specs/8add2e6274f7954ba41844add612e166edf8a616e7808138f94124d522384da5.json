  {
    "function_v0": {
      "doc": "Execute a multi-hop atomic arb.\\n\\nFlow:\\n1. `caller` authorises this invocation (must include token transfer auth).\\n2. Contract pulls `amount_in` of `token_in` from `caller`.\\n3. Each hop executes a cross-contract DEX swap.\\n4. Final balance is verified against `min_final_out`; panics if below.\\n5. Final tokens are returned to `caller`.\\n\\nFor cyclic arbs, `token_in` equals the last hop's output token.\\nReturns the final output amount.",
      "name": "execute",
      "inputs": [
        {
          "doc": "",
          "name": "caller",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "token_in",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "amount_in",
          "type_": "i128"
        },
        {
          "doc": "",
          "name": "min_final_out",
          "type_": "i128"
        },
        {
          "doc": "",
          "name": "hops",
          "type_": {
            "vec": {
              "element_type": {
                "udt": {
                  "name": "Hop"
                }
              }
            }
          }
        }
      ],
      "outputs": [
        "i128"
      ]
    }
  }
