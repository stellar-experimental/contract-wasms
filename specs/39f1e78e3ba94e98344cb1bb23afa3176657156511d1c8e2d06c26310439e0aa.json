    "udt_union_v0": {
      "doc": "Persistent storage keys for factory-managed data.\\n\\nWe store:\\n- a mapping from an asset-specific salt \\xe2\\x86\\x92 deployed pair address\\n- a global list of every deployed pair address (for discovery / indexing)",
      "lib": "",
      "name": "DataKey",
      "cases": [
        {
          "tuple_v0": {
            "doc": "Map: `salt` \\xe2\\x86\\x92 `pair_address`.\\n\\n`salt` is typically derived from asset metadata so that:\\n- pair deployments are deterministic / idempotent per asset\\n- callers can look up the canonical pair for a given asset",
            "name": "AssetPair",
            "type_": [
              {
                "bytes_n": {
                  "n": 32
                }
              }
            ]
          }
        },
        {
          "void_v0": {
            "doc": "Global append-only list of all pairs deployed by this factory.\\n\\nUsed for discovery (frontends), analytics, and indexers.",
