    "function_v0": {
      "doc": "Claim rewards using merkle proof\\n\\nUser provides:\\n- epoch: Which epoch to claim from\\n- amount: Their reward amount (stroops)\\n- merkle_proof: Sibling hashes from leaf to root\\n- proof_directions: Direction at each level (0=left, 1=right)\\n\\nThe leaf is computed as: SHA256(wallet || amount_le_bytes)",
      "name": "claim",
      "inputs": [
        {
          "doc": "",
          "name": "claimer",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "epoch",
          "type_": "u32"
        },
        {
          "doc": "",
          "name": "amount",
          "type_": "i128"
        },
        {
          "doc": "",
          "name": "merkle_proof",
          "type_": {
            "vec": {
              "element_type": {
                "bytes_n": {
                  "n": 32
                }
              }
            }
          }
        },
        {
          "doc": "",
          "name": "proof_directions",
          "type_": {
            "vec": {
              "element_type": "u32"
            }
          }
        }
      ],
      "outputs": []
    }
  },
