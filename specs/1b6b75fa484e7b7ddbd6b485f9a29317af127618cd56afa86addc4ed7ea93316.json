    "function_v0": {
      "doc": "Register a new epoch's merkle root (admin only)\\nCalled weekly by settlement cron job\\n\\nThe merkle tree leaves are: SHA256(wallet_address || amount_le_bytes)\\nThis allows users to prove their reward amount\\n\\nParameters:\\n- epoch: Sequential epoch number (0, 1, 2, ...)\\n- merkle_root: Root of the merkle tree for this epoch\\n- total_claimable: Sum of all rewards in this epoch (for accounting)\\n- vesting_ledgers: Number of ledgers until claims are available (~1 week)",
      "name": "register_epoch",
      "inputs": [
        {
          "doc": "",
          "name": "caller",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "epoch",
          "type_": "u32"
        },
        {
          "doc": "",
          "name": "merkle_root",
          "type_": {
            "bytes_n": {
              "n": 32
            }
          }
        },
        {
          "doc": "",
          "name": "total_claimable",
          "type_": "i128"
        },
        {
          "doc": "",
          "name": "vesting_ledgers",
          "type_": "u32"
        }
      ],
      "outputs": []
    }
  },
