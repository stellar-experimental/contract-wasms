  {
    "udt_struct_v0": {
      "doc": "Soroswap (Uniswap-V2 constant-product) pair. Unlike every other venue the pair\\ndoes NOT compute the output: the router reads `get_reserves()`, computes the\\n0.3%-fee output itself, then uses the UniV2 *push* model \\xe2\\x80\\x94 it transfers the input\\nstraight into the pair and calls `swap(amount_0_out, amount_1_out, to)`. The pair\\nhas NO `require_auth` (it enforces the K-invariant against its own balance), so\\nno authorization tree is needed \\xe2\\x80\\x94 the router just pushes its own funds (the same\\nway it pays the user). `zero_for_one` = `token_in` is the pair's `token_0`, which\\nfixes both the reserve ordering and which `amount_N_out` carries the output.",
      "lib": "",
      "name": "SoroswapStep",
      "fields": [
        {
          "doc": "",
          "name": "amount_in",
          "type_": "i128"
        },
        {
          "doc": "",
          "name": "pool",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "token_in",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "zero_for_one",
          "type_": "bool"
        }
      ]
    }
  },
