  {
    "function_v0": {
      "doc": "Identical to `swap_split` in args and economics, but FIRST establishes the user's\\n`asset_out` trustline in this same transaction (CAP-73 SAC `trust`) so a swap into a\\nfresh CLASSIC asset settles without a separate ChangeTrust tx. The backend calls this\\nin place of `swap_split` ONLY when the output is a classic-asset SAC the user does not\\nyet trust \\xe2\\x80\\x94 never for Soroban-native tokens (no trustline / no `trust` fn). The `trust`\\ncall is a no-op if the trustline already exists, and its `user.require_auth()` is\\ncovered by the user's existing source-account signature (no extra signature).",
      "name": "swap_split_trust",
      "inputs": [
        {
          "doc": "",
          "name": "user",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "asset_in",
          "type_": "address"
        },
