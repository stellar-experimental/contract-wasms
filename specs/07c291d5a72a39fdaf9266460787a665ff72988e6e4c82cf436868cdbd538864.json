[
  {
    "function_v0": {
      "doc": "Execute a swap atomically (single-path or split-order).\\n\\n`sub_routes` is always a list of legs; a simple swap is one entry with the full\\n`amount_in` and its hop `steps`. Split execution uses multiple entries.\\n\\nFlow:\\n1. Pull total input from user (sum of sub-route amounts)\\n2. For each sub-route: execute its path with its allocated amount\\n3. Sum outputs (all must produce the same `token_out`)\\n4. Verify total output >= `min_amount_out`\\n5. Transfer total output to user",
      "name": "swap",
      "inputs": [
        {
          "doc": "",
          "name": "user",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "token_in",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "token_out",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "sub_routes",
          "type_": {
            "vec": {
              "element_type": {
                "udt": {
                  "name": "SubRoute"
                }
              }
            }
          }
        },
        {
          "doc": "",
          "name": "min_amount_out",
          "type_": "i128"
        }
      ],
      "outputs": [
        "i128"
      ]
    }
  },
