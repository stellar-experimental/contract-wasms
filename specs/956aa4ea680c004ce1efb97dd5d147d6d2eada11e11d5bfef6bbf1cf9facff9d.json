  {
    "function_v0": {
      "doc": "Execute a cyclic arbitrage atomically\\n\\nThe entire transaction reverts if the final balance is less than\\ninitial balance + min_profit. This ensures atomic safety.\\n\\n# Arguments\\n* `initiator` - The caller who initiated the arbitrage\\n* `base_asset` - The asset we start and end with (e.g., USDC)\\n* `legs` - Vector of swap instructions\\n* `min_profit` - Minimum profit required (reverts if not met)\\n\\n# Returns\\n* `ArbResult` - Profit, fees, and legs executed",
      "name": "execute_cycle",
      "inputs": [
        {
          "doc": "",
          "name": "initiator",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "base_asset",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "legs",
          "type_": {
            "vec": {
              "element_type": {
                "udt": {
                  "name": "SwapLeg"
                }
              }
            }
          }
        },
        {
          "doc": "",
          "name": "min_profit",
          "type_": "i128"
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": {
              "udt": {
                "name": "ArbResult"
              }
            },
            "error_type": "error"
          }
        }
      ]
    }
  },
  {
