[
  {
    "udt_error_enum_v0": {
      "doc": "",
      "lib": "",
      "name": "Error",
      "cases": [
        {
          "doc": "The engine has not been wired to a VAMM yet (see `set_vamm`).",
          "name": "VammNotSet",
          "value": 1
        },
        {
          "doc": "Token is not configured as margin-eligible (see `set_margin_asset_config`).",
          "name": "AssetNotConfigured",
          "value": 2
        },
        {
          "doc": "Withdrawal exceeds the account's balance for that token.",
          "name": "InsufficientBalance",
          "value": 3
        },
        {
          "doc": "`settle_position` was called before the pool reached `term_end`.",
          "name": "PoolNotMatured",
          "value": 4
        },
        {
          "doc": "The APR oracle returned an invalid variable factor for the position's term.",
          "name": "InvalidAprRate",
          "value": 5
        },
        {
          "doc": "A pool with an open position has no worst-case variable factor configured.",
          "name": "WorstCaseNotSet",
          "value": 6
        },
        {
          "doc": "A collateral/underlying price needed for valuation was missing or stale.",
          "name": "StalePrice",
          "value": 7
        },
        {
          "doc": "Post-action LTV-discounted collateral does not cover the worst-case obligation.",
          "name": "InsufficientMargin",
          "value": 8
        },
        {
          "doc": "`settle_position` was called for a position the account does not hold.",
          "name": "PositionNotFound",
          "value": 9
        },
        {
          "doc": "Liquidation attempted on an account that is not below its liquidation threshold.",
          "name": "CannotLiquidate",
          "value": 10
        },
        {
          "doc": "Liquidation target position has no fixed-token debt to cover (`fixedBalance >= 0`).",
          "name": "PositionNotInDebt",
          "value": 11
        },
        {
          "doc": "A partial liquidation would leave dust (sub-threshold) collateral or debt behind.",
          "name": "DustResidue",
          "value": 12
        },
        {
          "doc": "The unwind swap did not fully close the position's variable leg.",
          "name": "VariableTokensNotFullyLiquidated",
          "value": 13
        }
      ]
    }
  },
