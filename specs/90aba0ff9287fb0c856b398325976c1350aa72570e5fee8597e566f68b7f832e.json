  {
    "function_v0": {
      "doc": "Set the swap configuration for the next operation\\nThis should be called before initiating a flash loan\\n\\nArguments:\\n- caller: The address setting the config (no auth required)\\n- token_out: Final output token address\\n- min_amount_out: Minimum output amount (slippage protection)\\n- swap_chain: Custom swap chain (Vec of SwapHop). If empty, builds default direct swap.\\n\\nNote: No auth required as this is a temporary config cleared after exec_op",
      "name": "set_swap_config",
      "inputs": [
        {
          "doc": "",
          "name": "caller",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "token_out",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "min_amount_out",
          "type_": "i128"
        },
        {
          "doc": "",
          "name": "swap_chain",
          "type_": {
            "vec": {
              "element_type": {
                "udt": {
                  "name": "SwapHop"
                }
              }
            }
          }
        }
      ],
      "outputs": []
    }
  },
