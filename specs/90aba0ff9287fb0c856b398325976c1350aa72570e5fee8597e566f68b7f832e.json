  {
    "function_v0": {
      "doc": "exec_op - The callback function called by Blend Pool during flash loan\\n\\nThis is the Modified ERC-3156 interface that Blend uses.\\nThe pool calls this function after transferring the flash loan tokens.\\n\\nBehavior:\\n1. Receives flash loaned tokens\\n2. If swap config is set, swaps tokens via Aquarius AMM\\n3. Transfers output tokens to the caller (user)\\n\\nArguments:\\n- caller: The address that initiated the flash loan\\n- token: The token address being flash loaned (token_in for swap)\\n- amount: The amount of tokens received\\n- fee: The fee for the flash loan (currently 0 in Blend)",
      "name": "exec_op",
      "inputs": [
        {
          "doc": "",
          "name": "caller",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "token",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "amount",
          "type_": "i128"
        },
        {
          "doc": "",
          "name": "fee",
          "type_": "i128"
        }
      ],
      "outputs": []
    }
  },
