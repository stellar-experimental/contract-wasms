    "udt_enum_v0": {
      "doc": "Lifecycle of a single ticket.\\n- `Valid`    : bought, escrowed, not yet used.\\n- `Used`     : the organizer checked the holder in; price settled to organizer.\\n- `Refunded` : the buyer reclaimed the price before the event started.",
      "lib": "",
      "name": "TicketStatus",
