        {
          "doc": "",
          "name": "Refunded",
          "value": 2
        }
      ]
    }
  },
  {
    "udt_struct_v0": {
      "doc": "An on-chain event. Funds for its tickets are escrowed in the contract until\\neach ticket is either checked in (settles to the organizer) or refunded\\n(returns to the buyer).",
      "lib": "",
      "name": "Event",
      "fields": [
        {
          "doc": "Maximum number of tickets that can be sold.",
          "name": "capacity",
          "type_": "u32"
        },
        {
          "doc": "Creator and the only address allowed to check attendees in.",
          "name": "organizer",
          "type_": "address"
        },
        {
          "doc": "Ticket price in the token's minor units (XLM = 7 decimals / stroops).\\n`0` = free entry.",
          "name": "price",
          "type_": "i128"
        },
        {
          "doc": "Tickets sold so far.",
          "name": "sold",
          "type_": "u32"
        },
        {
          "doc": "Unix timestamp (ledger time). Refunds are allowed strictly before this.",
          "name": "start_time",
          "type_": "u64"
        },
        {
          "doc": "",
          "name": "status",
          "type_": {
            "udt": {
              "name": "EventStatus"
            }
          }
        }
      ]
    }
  },
