  {
    "function_v0": {
      "doc": "Verify a RISC Zero proof and mint KALIEN tokens.\\n\\n- `seal`: variable-length proof seal bytes\\n- `journal_raw`: raw 49-byte journal bytes:\\n- 4 x u32 LE fields (`seed_id`, `seed`, `frame_count`, `final_score`)\\n- claimant payload (kind + 32-byte id)\\n\\nReturns the claimant's new best score for this `seed_id`.\\n\\nErrors:\\n- `ContractPaused` if submissions are disabled.\\n- `InvalidJournalFormat` for malformed journal data.\\n- `SeedNotActive` if the `(seed_id, seed)` pair is not active.\\n- `JournalAlreadyClaimed` on replay.\\n- `ZeroScoreNotAllowed` or `ScoreNotImproved` for policy violations.",
      "name": "submit_score",
      "inputs": [
        {
          "doc": "",
          "name": "seal",
          "type_": "bytes"
        },
        {
          "doc": "",
          "name": "journal_raw",
          "type_": "bytes"
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": "u32",
            "error_type": {
              "udt": {
                "name": "ScoreError"
              }
            }
          }
        }
      ]
    }
  },
