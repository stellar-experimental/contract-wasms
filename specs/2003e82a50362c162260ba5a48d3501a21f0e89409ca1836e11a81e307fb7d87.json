    "function_v0": {
      "doc": "Approve multiple tokens at once, then perform round-trip transfer\\n\\nFirst approves a wallet for all tokens in the list, then:\\n- Owner sends token to contract\\n- Contract sends token back to owner\\n\\nParameters:\\n- owner: User initiating the approvals and transfer (must sign)\\n- tokens: List of token contracts to approve\\n- token_from_owner: Token owner is sending\\n- amount_from_owner: Amount owner is sending\\n- token_to_owner: Unused (kept for compatibility)\\n- amount_to_owner: Unused (kept for compatibility)",
      "name": "swap",
      "inputs": [
        {
          "doc": "",
          "name": "owner",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "tokens",
          "type_": {
            "vec": {
              "element_type": "address"
            }
          }
        },
        {
          "doc": "",
          "name": "token_from_owner",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "amount_from_owner",
          "type_": "i128"
        },
        {
          "doc": "",
          "name": "token_to_owner",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "amount_to_owner",
          "type_": "i128"
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": {
              "tuple": {
                "value_types": []
              }
            },
            "error_type": {
              "udt": {
                "name": "SwapError"
              }
            }
          }
        }
      ]
    }
  }
