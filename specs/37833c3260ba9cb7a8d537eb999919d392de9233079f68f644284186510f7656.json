  {
    "udt_struct_v0": {
      "doc": "Guard-rail parameters applied to raw oracle updates before they are exposed\\nto downstream consumers (Treasury, Pair, etc.).\\n\\nThese values define *when* a price is considered stale or unsafe, and *how*\\naggressively new oracle prices are clamped relative to historical values.",
      "lib": "",
      "name": "GuardRails",
      "fields": [
        {
          "doc": "Controls how tightly new oracle prices are clamped to historical prices.\\n\\nThe allowed band is:\\n```text\\nlast_price \\xc2\\xb1 (last_price / sanitize_clamp_denominator)\\n```\\n\\nExample:\\n- `sanitize_clamp_denominator = 10` \\xe2\\x86\\x92 \\xc2\\xb110% per update",
          "name": "sanitize_clamp_denominator",
          "type_": "u128"
        },
        {
          "doc": "Maximum age (in seconds) before an oracle price is considered stale.\\n\\nIf exceeded, consumers may reject the price or treat the oracle as unhealthy.",
          "name": "seconds_before_stale",
          "type_": "u64"
        },
        {
          "doc": "Maximum allowed relative price change between updates, expressed in\\n`PERCENTAGE_PRECISION_U64` units.\\n\\nUsed to detect abnormally volatile price jumps that may indicate oracle failure\\nor manipulation.",
          "name": "too_volatile_ratio",
          "type_": "u64"
        }
      ]
    }
  },
  {
    "udt_union_v0": {
      "doc": "Persistent data keys for historical oracle state.\\n\\nHistorical data is kept in persistent storage so it survives across\\nledger boundaries and can be used for TWAPs, volatility checks, and clamping.",
      "lib": "",
      "name": "DataKey",
      "cases": [
        {
          "void_v0": {
            "doc": "Stores the rolling oracle history (TWAP, last price, timestamps, etc.).",
            "name": "HistoricalData"
          }
        }
      ]
    }
