    "udt_struct_v0": {
      "doc": "Per-asset spend ceiling tracked across the lifetime of the policy.\\n\\nMirrors the Go-side `SessionPermissions.MaxValuePerTx` / `MaxTotalValue`\\n(`services/risk-api/services/smart_account_client.go:58-66`) and adds\\nrolling-window accounting so a session that lives across many calls cannot\\ndrain a wallet by burst.\\n\\nWindow semantics: `period_used` resets to 0 the first time\\n`now.saturating_sub(period_start) >= period_seconds`. `total_used` never\\nresets and caps the cumulative outflow for the lifetime of the policy.",
      "lib": "",
      "name": "AssetCap",
      "fields": [
        {
          "doc": "",
          "name": "max_per_tx",
          "type_": "i128"
        },
        {
          "doc": "",
          "name": "max_period_amount",
          "type_": "i128"
        },
