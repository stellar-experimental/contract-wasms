    "function_v0": {
      "doc": "Admin-only setter for the Reflector aggregator contract address used\\nby the swap-auth path. Until set, every swap auth fails closed with\\n`Error::OracleStale`. Operators MUST verify the address against\\n<https://reflector.network/docs> before invoking this on mainnet \\xe2\\x80\\x94\\npointing at the wrong contract is a slippage-bypass vector.",
      "name": "set_oracle_aggregator",
      "inputs": [
        {
          "doc": "",
          "name": "aggregator",
          "type_": "address"
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": "void",
            "error_type": "error"
          }
        }
      ]
    }
  },
  {
    "udt_struct_v0": {
      "doc": "On-chain caveat set enforced by `__check_auth`.\\n\\nField meanings:\\n- `allowed_contracts`: Soroban contract IDs the session may invoke (e.g.\\nthe Blend pool, the Soroswap router). Admin signers are not bound by\\nthis list.\\n- `allowed_functions`: function symbols the session may call. The canonical\\n`(Address token, i128 amount, ...)` shape covers `supply`, `withdraw`,\\n`borrow`, `repay`, `claim`. `swap_exact_tokens_for_tokens` follows the\\nSoroswap shape `(amount_in, amount_out_min, path, to, deadline)` and is\\nadmitted in A2b. Any other allowlisted name with no registered decoder\\nreturns `FunctionNotSupportedInA1`.\\n- `asset_caps`: per-token spend limits. For swaps, the input token\\n(`path[0]`) is debited; the output token is not debited because it is\\nreceived, not spent.\\n- `leverage_band_min_bps`/`leverage_band_max_bps`: stored only. Off-chain\\npre-flight in `risk-api` enforces the band against post-call state.\\n- `hf_floor_bps`: stored only, off-chain enforced.\\n- `slippage_bps_max`: enforced on-chain for swaps in A2b. ",
      "lib": "",
      "name": "Policy",
      "fields": [
        {
          "doc": "",
          "name": "allowed_contracts",
          "type_": {
            "vec": {
              "element_type": "address"
            }
          }
        },
        {
          "doc": "",
          "name": "allowed_functions",
          "type_": {
            "vec": {
              "element_type": "symbol"
            }
          }
        },
        {
          "doc": "",
          "name": "asset_caps",
          "type_": {
            "map": {
              "key_type": "address",
              "value_type": {
                "udt": {
                  "name": "AssetCap"
                }
              }
            }
          }
        },
        {
          "doc": "",
          "name": "expiry_ledger",
          "type_": "u32"
        },
        {
          "doc": "",
          "name": "hf_floor_bps",
          "type_": "u32"
        },
        {
          "doc": "",
          "name": "leverage_band_max_bps",
          "type_": "u32"
        },
        {
          "doc": "",
          "name": "leverage_band_min_bps",
          "type_": "u32"
        },
        {
          "doc": "",
          "name": "slippage_bps_max",
          "type_": "u32"
        }
      ]
    }
  },
