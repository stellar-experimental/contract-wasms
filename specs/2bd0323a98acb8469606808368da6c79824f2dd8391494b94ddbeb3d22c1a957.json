  {
    "udt_error_enum_v0": {
      "doc": "",
      "lib": "",
      "name": "ContractError",
      "cases": [
        {
          "doc": "Deprecated: retained for ABI stability (was the issuer-whitelist model,\\nreplaced by open issuance + denylist). No longer raised.",
          "name": "IssuerNotAuthorized",
          "value": 2
        },
        {
          "doc": "Deprecated: retained for ABI stability (was the issuer-whitelist model).\\nNo longer raised.",
          "name": "IssuerAlreadyAuthorized",
          "value": 3
        },
        {
          "doc": "Vault is revoked; writes blocked.",
          "name": "VaultRevoked",
          "value": 4
        },
        {
          "doc": "VC not found in vault or status registry.",
          "name": "VCNotFound",
          "value": 6
        },
        {
          "doc": "VC already revoked.",
          "name": "VCAlreadyRevoked",
          "value": 7
        },
        {
          "doc": "Vault not initialized for this owner.",
          "name": "VaultNotInitialized",
          "value": 8
        },
        {
          "doc": "Contract not initialized (no admin).",
          "name": "NotInitialized",
          "value": 9
        },
        {
          "doc": "vault_contract param is not this contract.",
          "name": "InvalidVaultContract",
          "value": 10
        },
        {
          "doc": "vc_id already exists in this vault; re-issuance is not allowed.",
          "name": "VCAlreadyExists",
          "value": 12
        },
        {
          "doc": "accept_contract_admin called but no admin nomination is pending.",
          "name": "NoPendingAdmin",
          "value": 13
        },
        {
          "doc": "Vault has reached the maximum number of active VCs.",
          "name": "VaultFull",
          "value": 15
        },
        {
          "doc": "Pagination `limit` exceeds `MAX_LIST_LIMIT`.",
          "name": "LimitTooLarge",
          "value": 16
        },
        {
          "doc": "Batch issuance request exceeds `MAX_BATCH_SIZE`.",
          "name": "BatchTooLarge",
          "value": 17
        },
        {
          "doc": "Batch issuance called with an empty `vcs` list.",
          "name": "BatchEmpty",
          "value": 18
        },
        {
          "doc": "String input exceeds its per-field maximum length (vc_id, vc_data,\\ndid_uri, issuer_did, or date).",
          "name": "InputTooLong",
          "value": 19
        },
        {
          "doc": "Deprecated: retained for ABI stability (was the bulk authorize-issuers\\nlist cap). No longer raised.",
          "name": "IssuerListTooLong",
          "value": 20
        },
        {
          "doc": "Batch fee total (per-credential fee \\xc3\\x97 batch size) overflowed `i128`.",
          "name": "FeeOutOfBounds",
          "value": 23
        },
        {
          "doc": "Source vault is not registered in the factory.",
          "name": "SourceNotAVault",
          "value": 24
        },
        {
          "doc": "Issuer is in this vault's denied list.",
          "name": "IssuerDenied",
          "value": 25
        },
        {
          "doc": "receive_push source vault has a different owner than this vault.",
          "name": "PushOwnerMismatch",
          "value": 26
        }
      ]
    }
  },
