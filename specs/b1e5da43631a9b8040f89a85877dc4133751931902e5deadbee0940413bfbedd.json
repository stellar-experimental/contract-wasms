    "function_v0": {
      "doc": "Registers a boost campaign for a single-asset DeFindex vault. Admin must\\npass `asset` explicitly and the contract asserts the vault's\\n`get_assets()` returns the same address \\xe2\\x80\\x94 this prevents a malicious or\\nmisconfigured vault from steering subsequent `deposit` / `boost` token\\ntransfers to an unexpected token.",
      "name": "register_campaign",
      "inputs": [
        {
          "doc": "",
          "name": "vault",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "asset",
