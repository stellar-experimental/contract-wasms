    "function_v0": {
      "doc": "Proposes a new admin. The new address must call `accept_admin` to take\\nthe role. Calling again with a different address overwrites the pending\\nslot; calling with the current admin's own address effectively cancels.",
      "name": "propose_admin",
      "inputs": [
        {
          "doc": "",
          "name": "new_admin",
          "type_": "address"
        }
      ],
      "outputs": []
    }
  },
  {
    "function_v0": {
      "doc": "Sweeps tokens out of the treasury that aren't accounted for in any\\ncampaign \\xe2\\x80\\x94 direct transfers, refunds from a vault, dust, mistaken\\nsends. Admin only.\\n\\nThe function computes `orphan = balance(token) - sum_of_available()` for\\nevery campaign whose `asset == token`, and refuses to send more than\\n`orphan`. This bound ensures that an admin typo cannot move tokens\\nattributed to an active campaign \\xe2\\x80\\x94 `rescue_orphan` is strictly safer\\nthan `transfer()` for handling unaccounted balances.",
      "name": "rescue_orphan",
      "inputs": [
        {
          "doc": "",
          "name": "token",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "to",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "amount",
          "type_": "i128"
        }
      ],
      "outputs": []
    }
  },
