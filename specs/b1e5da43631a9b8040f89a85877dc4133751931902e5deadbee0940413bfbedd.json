  {
    "function_v0": {
      "doc": "Sends `amount` tokens from a campaign's tracked budget to `to`. Admin\\nonly. Used for refunds (returning unspent budget to depositors) or for\\nreallocating between vaults.\\n\\n\\xe2\\x9a\\xa0\\xef\\xb8\\x8f This function grants the admin role full power to drain any\\ncampaign's `available()` budget to any address. Depositors should be\\naware that admin can redirect their funds \\xe2\\x80\\x94 this is by design, the\\nadmin is the trusted operator of the treasury. For tokens that arrived\\nOUTSIDE `deposit()` (direct transfers, dust, mistaken sends), use\\n`rescue_orphan` instead, which is bounded by the campaign-tracked totals\\nand cannot accidentally move funds attributed to a campaign.",
      "name": "transfer",
      "inputs": [
        {
          "doc": "",
          "name": "vault",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "amount",
          "type_": "i128"
        },
        {
          "doc": "",
          "name": "to",
          "type_": "address"
        }
      ],
      "outputs": []
    }
  },
