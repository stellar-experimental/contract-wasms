        },
        {
          "doc": "`path` is malformed: empty, single-element, first != reward_token,\\nor last != strategy's asset.",
          "name": "InvalidPath",
          "value": 5
        },
        {
          "doc": "Off-chain caller's deadline has already passed by the time the tx\\nreached the validator. Resubmit with a fresher deadline.",
          "name": "DeadlinePassed",
          "value": 6
        },
        {
          "doc": "The router returned fewer asset tokens than `min_out`. Tighten the\\noff-chain quote / loosen `min_out` and resubmit.",
          "name": "SlippageExceeded",
          "value": 7
        },
        {
          "doc": "",
          "name": "UpgradeNotScheduled",
          "value": 8
        },
        {
          "doc": "",
          "name": "UpgradeTooEarly",
          "value": 9
        },
        {
          "doc": "Reward token must differ from the strategy's principal asset \\xe2\\x80\\x94\\ncompounding USDC into USDC is a no-op masquerading as yield.",
          "name": "InvalidRewardToken",
          "value": 10
        },
        {
          "doc": "`min_out` cannot be negative; pass 0 to accept any non-zero output.",
          "name": "InvalidMinOut",
          "value": 11
        },
        {
          "doc": "`set_upgrade_delay` was called with a delay below `MIN_UPGRADE_DELAY`.\\nAdmin must respect the timelock floor \\xe2\\x80\\x94 same posture as the strategies.",
          "name": "InvalidUpgradeDelay",
          "value": 12
        }
