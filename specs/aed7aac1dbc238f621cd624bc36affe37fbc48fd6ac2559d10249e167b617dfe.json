    "function_v0": {
      "doc": "Initialize the rewards module. Must be called once after deploy\\nbefore any other entry point becomes useful. Matches the\\n`initialize` pattern used by tezoro-vault and the strategies \\xe2\\x80\\x94 the\\nadmin's auth is captured at this call rather than at the deploy\\ntransaction, which makes deploys easier to script (no constructor\\nargs = no auth tree at deploy time) and lets the soroban-fork\\nharness register the wasm without needing a forked auth manager\\nfor the constructor context.",
      "name": "initialize",
      "inputs": [
        {
          "doc": "",
          "name": "admin",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "keeper",
