  {
    "udt_union_v0": {
      "doc": "Storage keys.\\n\\n`Principal(saver)` lives in *persistent* storage \\xe2\\x80\\x94 a saver's deposit must\\noutlive the contract instance's TTL window (their money is never lost).\\nEverything else (admin/token/aggregates/saver index) lives in *instance*\\nstorage so it shares the instance TTL bumped on every state-changing call.",
      "lib": "",
      "name": "DataKey",
      "cases": [
        {
          "void_v0": {
            "doc": "",
            "name": "Admin"
          }
        },
        {
          "void_v0": {
            "doc": "",
            "name": "Token"
          }
        },
        {
          "void_v0": {
            "doc": "",
            "name": "Paused"
          }
        },
        {
          "void_v0": {
            "doc": "Sum of every saver's withdrawable principal (escrowed, never raffled).",
            "name": "TotalPrincipal"
          }
        },
        {
          "void_v0": {
            "doc": "Admin/yield-funded prize that the next draw pays to the winner.",
            "name": "PrizePool"
          }
        },
        {
          "void_v0": {
            "doc": "Ordered index of addresses that currently hold a positive principal.",
            "name": "Savers"
          }
        },
        {
          "void_v0": {
            "doc": "Number of completed draws.",
            "name": "DrawCount"
          }
        },
        {
          "void_v0": {
            "doc": "Most recent winner (for views / UI).",
            "name": "LastWinner"
          }
        },
        {
          "void_v0": {
            "doc": "Prize paid in the most recent draw.",
            "name": "LastPrize"
          }
        },
        {
          "tuple_v0": {
            "doc": "saver -> withdrawable principal (minor units / stroops).",
            "name": "Principal",
            "type_": [
              "address"
            ]
          }
        }
      ]
    }
  },
