  {
    "function_v0": {
      "doc": "Deposit `amount` of underlying into Blend. Returns shares minted to `from`.\\n\\nShare math:\\n- First depositor (total_shares == 0): shares = amount (1:1 bootstrap).\\n- Subsequent: shares = delta_value * total_shares / value_before_deposit.\\nRounding DOWN \\xe2\\x80\\x94 protects existing depositors from dilution due to\\nrounding.",
      "name": "deposit",
      "inputs": [
        {
          "doc": "",
          "name": "amount",
          "type_": "i128"
        },
        {
          "doc": "",
          "name": "from",
          "type_": "address"
        }
      ],
      "outputs": [
        "i128"
      ]
    }
  },
  {
    "function_v0": {
      "doc": "Claim BLND emissions, swap via Soroswap \\xe2\\x86\\x92 asset, then redeposit into\\nBlend. Share price rises for all holders; no per-user distribution.\\n\\nNo-op if total_shares == 0 (prevents a 1-wei first-depositor from\\nharvesting pre-accrued emissions for free).",
      "name": "harvest",
      "inputs": [
        {
          "doc": "",
          "name": "from",
          "type_": "address"
        }
      ],
      "outputs": [
        "i128"
      ]
    }
  },
