  {
    "function_v0": {
      "doc": "Burn `shares_to_burn` shares held by `from`, pay out proportional\\nunderlying to `to`.\\n\\n`amount` parameter is REUSED as `shares_to_burn` under the v4 share\\nmodel. Do not pass underlying amount.\\n\\nReverts if `shares_to_burn > Shares(from)` \\xe2\\x80\\x94 fixes the C2 drain.",
      "name": "withdraw",
      "inputs": [
        {
          "doc": "",
          "name": "amount",
          "type_": "i128"
        },
        {
          "doc": "",
          "name": "from",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "to",
          "type_": "address"
        }
      ],
      "outputs": [
        "i128"
      ]
    }
