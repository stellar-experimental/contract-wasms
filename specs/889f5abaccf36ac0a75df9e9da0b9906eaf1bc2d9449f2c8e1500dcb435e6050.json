  {
    "function_v0": {
      "doc": "Record funds bridged BACK into the vault from the cross-chain endpoint.\\n\\nAuthorized by the configured endpoint itself \\xe2\\x80\\x94 mirroring `deposit`'s\\n`from.require_auth()` so the inbound transfer is rooted in the caller's\\nauthorization. Funds can therefore only arrive from the designated\\nsource. Reduces the bridged tally by up to its current value (never\\nnegative). Cost-basis: any surplus over the recorded principal lands as\\nreal idle and is realized yield \\xe2\\x80\\x94 it cannot be fabricated, because the\\ntokens must actually move. Not gated by the cross-chain pause: inflows\\nare a recovery path and must stay open while outflows are halted.",
      "name": "record_bridge_in",
      "inputs": [
        {
          "doc": "",
          "name": "amount",
          "type_": "i128"
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": "void",
            "error_type": {
              "udt": {
                "name": "VaultError"
              }
            }
          }
        }
      ]
    }
  },
