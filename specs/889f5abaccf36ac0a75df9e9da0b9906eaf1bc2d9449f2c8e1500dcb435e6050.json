  {
    "function_v0": {
      "doc": "Redeem shares for assets. Allowed while paused (users can always exit).\\n\\nWithdrawal waterfall: idle first, then iterate strategies pulling the\\nshortfall via `strategy.withdraw()`. Each hop is capped by the\\nstrategy's self-reported `available_liquidity()` so we never request\\nmore than the underlying yield source can actually deliver on the\\ncurrent ledger (e.g. a Blend pool at 100% utilization has\\n`balance_of > 0` but `available_liquidity == 0` until repayments\\narrive). This removes the user's dependency on the keeper for exits:\\nwhatever the vault holds across idle + strategies is redeemable in a\\nsingle transaction, without a prior admin/keeper deallocation call.\\n\\nException \\xe2\\x80\\x94 cross-chain funds: a redeem whose marked NAV includes the\\nbridged (off-Stellar) portion can't be fully served on-chain, since the\\nwaterfall can't pull bridged funds. The bounded-shortfall guard below\\nreverts such an over-large exit (rather than underpaying); that fraction\\nstays illiquid until a keeper `record_bridge_in` recalls it.",
      "name": "redeem",
      "inputs": [
        {
          "doc": "",
          "name": "from",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "shares",
          "type_": "i128"
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": "i128",
            "error_type": {
              "udt": {
                "name": "VaultError"
              }
            }
          }
        }
      ]
    }
  },
