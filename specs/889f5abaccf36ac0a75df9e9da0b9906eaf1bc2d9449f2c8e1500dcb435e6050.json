      "outputs": [
        "bool"
      ]
    }
  },
  {
    "function_v0": {
      "doc": "Reconcile a strategy's tracked balance with NO deviation bound. For\\nadmin/guardian use when a strategy's balance legitimately moves more\\nthan the routine keeper band allows in one step: the initial\\npost-allocate sync, a large realized gain/loss, or recovery after a\\ntransient `balance_of()` anomaly. Value still comes from the strategy\\nitself, never from caller input.",
      "name": "force_sync_tracked_balance",
      "inputs": [
        {
          "doc": "",
          "name": "caller",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "strategy",
          "type_": "address"
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": "void",
            "error_type": {
              "udt": {
                "name": "VaultError"
              }
            }
          }
        }
      ]
    }
  },
