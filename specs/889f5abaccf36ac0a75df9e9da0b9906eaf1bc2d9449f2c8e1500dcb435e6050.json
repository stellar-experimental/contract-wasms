  {
    "function_v0": {
      "doc": "Re-attest that the recorded bridged balance is still valid, refreshing\\nits timestamp WITHOUT moving any funds.\\n\\n`record_bridge_out`/`record_bridge_in` are the only other writers of the\\nbridged timestamp, and both move tokens \\xe2\\x80\\x94 so a position parked on the\\nremote chain (earning yield, nothing to move yet) would otherwise go\\nstale after `bridged_max_age` and block deposits. This is the keeper's\\nliveness proof: it cannot fabricate value (the tally is unchanged), it\\nonly says \"the cross-chain position is still there.\" Gated by BOTH\\npause switches on purpose \\xe2\\x80\\x94 during an incident we WANT the balance to go\\nstale (total_assets then writes it off conservatively), so a paused or\\ncross-chain-paused vault stops accepting heartbeats and lets staleness\\nkick in. That gating is the counter to the one risk this adds: a\\ncompromised-but-active keeper could otherwise heartbeat a bridged balance\\nwhose remote backing is gone, keeping total_assets inflated (bounded by\\nthe real bridged-out amount, and non-extractable \\xe2\\x80\\x94 redeem c",
      "name": "heartbeat_bridged",
      "inputs": [
        {
          "doc": "",
          "name": "keeper",
          "type_": "address"
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": "void",
            "error_type": {
              "udt": {
                "name": "VaultError"
              }
            }
          }
        }
      ]
    }
  },
  {
    "function_v0": {
      "doc": "Halt cross-chain outflows (admin or guardian). record_bridge_out\\nreverts while paused; record_bridge_in stays open so funds can return.",
      "name": "pause_cross_chain",
      "inputs": [
        {
          "doc": "",
          "name": "caller",
          "type_": "address"
        }
      ],
