  {
    "function_v0": {
      "doc": "Emergency circuit-breaker (admin or guardian). Freezes every\\nrisk-increasing flow \\xe2\\x80\\x94 deposit, allocate, record_bridge_out \\xe2\\x80\\x94 while\\nleaving exits and unwinds open: redeem, deallocate,\\nemergency_withdraw_strategy and record_bridge_in keep working so the\\nsystem can be wound down safely. unpause() is admin-only.",
      "name": "pause",
      "inputs": [
        {
          "doc": "",
          "name": "caller",
          "type_": "address"
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": "void",
            "error_type": {
              "udt": {
                "name": "VaultError"
              }
            }
          }
        }
      ]
    }
  },
