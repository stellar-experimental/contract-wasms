  {
    "function_v0": {
      "doc": "Reconcile a strategy's tracked balance to its on-chain self-reported\\nbalance.\\n\\nKeeper-only, but the value comes from the strategy itself via\\n`balance_of()` \\xe2\\x80\\x94 NOT from keeper input. This removes the free-form\\nmanipulation vector the old `update_tracked_balance` had, where a\\ncompromised keeper could write an arbitrary tracked balance to distort\\n`total_assets()` (and hence share price). Strategies are admin-vetted,\\nso trusting their `balance_of()` is the intended trust boundary. Use\\nthis to fold strategy-side yield into the vault's accounting.",
      "name": "sync_tracked_balance",
      "inputs": [
        {
          "doc": "",
          "name": "keeper",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "strategy",
          "type_": "address"
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": "void",
            "error_type": {
              "udt": {
                "name": "VaultError"
              }
            }
          }
        }
      ]
    }
  },
  {
    "function_v0": {
      "doc": "",
