    "function_v0": {
      "doc": "Admin-gated in-place Wasm upgrade (CAP-0054). Preserves the contract\\nID and all persistent + instance storage (balances, admin key, token\\nmetadata, allowances).\\n\\nWithout this entrypoint, any Phase 4.5 re-deploy path would mint a\\nnew contract ID and orphan every ZMOKE balance permanently \\xe2\\x80\\x94 which\\nis survivable on testnet (we patch wrangler.jsonc and move on) but\\ncatastrophic on mainnet.\\n\\nWorkflow: `stellar contract install` uploads the new Wasm blob and\\nreturns its sha256 hash; this function swaps the running contract's\\ncode to that hash. Caller must be the current admin.",
      "name": "upgrade",
      "inputs": [
        {
          "doc": "",
          "name": "new_wasm_hash",
          "type_": {
            "bytes_n": {
              "n": 32
            }
          }
        }
      ],
      "outputs": []
    }
  },
