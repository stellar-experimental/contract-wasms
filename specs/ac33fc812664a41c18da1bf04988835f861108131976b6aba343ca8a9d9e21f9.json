          }
        }
      ]
    }
  },
  {
    "function_v0": {
      "doc": "A violator repays their share of a past round's beneficiary shortfall. The funds flow\\nstraight to that round's beneficiary (credited, pull-based). Clears the caller's debt\\nfor that round; once their total Owed reaches 0 AND the lockout is served they leave\\nthe penalty box. I1 holds throughout: the contract balance and \\xce\\xa3 claimable both rise\\nby the repaid amount in the same call (money in \\xe2\\x86\\x92 beneficiary's claim funded).",
      "name": "repay",
      "inputs": [
        {
          "doc": "",
          "name": "member",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "round",
          "type_": "u64"
        }
      ],
      "outputs": [
        {
          "result": {
