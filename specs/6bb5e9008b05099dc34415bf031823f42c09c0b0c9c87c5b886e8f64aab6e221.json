    "function_v0": {
      "doc": "Propose a WASM upgrade of the factory's OWN code. Starts the fixed\\nupgrade timelock ([`UPGRADE_COOLDOWN_SECS`]) before the new code can be\\napplied.\\n\\nWASM replacement is the most powerful operation in the protocol, so \\xe2\\x80\\x94\\nunlike a single-step `upgrade` \\xe2\\x80\\x94 it is split into a timelocked\\npropose/accept flow. The proposed hash is recorded and bound:\\n`accept_upgrade` applies exactly this hash, so the timelock cannot be\\nbypassed by proposing a benign hash and later applying a different one.",
      "name": "propose_upgrade",
      "inputs": [
        {
          "doc": "",
          "name": "new_wasm_hash",
          "type_": {
            "bytes_n": {
              "n": 32
            }
          }
        },
        {
          "doc": "",
          "name": "operator",
          "type_": "address"
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": {
              "tuple": {
                "value_types": []
              }
            },
            "error_type": {
              "udt": {
                "name": "FactoryUpgradeError"
              }
            }
          }
        }
      ]
    }
  },
