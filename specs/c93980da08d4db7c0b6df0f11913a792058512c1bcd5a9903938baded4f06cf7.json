  {
    "event_v0": {
      "doc": "Event emitted when tokens are transferred between addresses without a\\nmuxed destination.\\n\\nPer SEP-41, the event data is a bare `i128` when no muxed address is\\ninvolved. The `data_format = \"single-value\"` attribute ensures the\\n`amount` field is serialized as a bare value rather than a map.",
      "lib": "",
      "name": "Transfer",
      "prefix_topics": [
        "transfer"
      ],
      "params": [
        {
          "doc": "",
          "name": "from",
          "type_": "address",
          "location": "topic_list"
        },
        {
          "doc": "",
          "name": "to",
          "type_": "address",
          "location": "topic_list"
        },
        {
          "doc": "",
          "name": "amount",
          "type_": "i128",
          "location": "data"
        }
      ],
      "data_format": "single_value"
    }
  },
  {
    "event_v0": {
      "doc": "Event emitted when tokens are transferred to a muxed address.\\n\\nPer SEP-41, when the destination is a [`MuxedAddress`] the event data\\ncarries both the amount and the muxed identifier so that off-chain\\nconsumers can attribute the transfer to the correct sub-account.\\n\\nUses `topics = [\"transfer\"]` so that both [`Transfer`] and\\n[`MuxedTransfer`] share the same `\"transfer\"` event symbol, as required\\nby SEP-41.",
      "lib": "",
      "name": "MuxedTransfer",
      "prefix_topics": [
        "transfer"
      ],
      "params": [
        {
          "doc": "",
          "name": "from",
          "type_": "address",
          "location": "topic_list"
        },
        {
          "doc": "",
          "name": "to",
          "type_": "address",
          "location": "topic_list"
        },
        {
          "doc": "",
          "name": "to_muxed_id",
          "type_": {
            "option": {
              "value_type": "u64"
            }
          },
          "location": "data"
        },
        {
          "doc": "",
          "name": "amount",
          "type_": "i128",
          "location": "data"
        }
      ],
      "data_format": "map"
    }
  },
