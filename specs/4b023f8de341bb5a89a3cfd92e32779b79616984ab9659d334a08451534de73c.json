  {
    "udt_error_enum_v0": {
      "doc": "All errors that the PhoenixLpStrategy contract can raise.",
      "lib": "",
      "name": "PhoenixLpError",
      "cases": [
        {
          "doc": "`initialize` was already called on this contract instance.",
          "name": "AlreadyInitialized",
          "value": 1
        },
        {
          "doc": "An entry-point that requires prior initialization was called before\\n`initialize`.",
          "name": "NotInitialized",
          "value": 2
        },
        {
          "doc": "The caller of `deposit_liquidity` or `withdraw` is not the registered\\nvault address.",
          "name": "NotVault",
          "value": 3
        },
        {
          "doc": "The caller of `pause` or `unpause` is not the registered manager address.",
          "name": "NotManager",
          "value": 4
        },
        {
          "doc": "The strategy is currently paused; `deposit_liquidity` and `withdraw`\\nare blocked.",
          "name": "Paused",
          "value": 5
        },
        {
          "doc": "A zero or negative amount was supplied where a strictly-positive value\\nis required.",
          "name": "InvalidAmount",
          "value": 6
        },
        {
          "doc": "The requested share-token withdrawal amount exceeds the strategy's\\ntracked Phoenix share token balance.",
          "name": "InsufficientShares",
          "value": 7
        },
        {
          "doc": "An arithmetic operation overflowed `i128`.",
          "name": "Overflow",
          "value": 8
        },
        {
          "doc": "The oracle returned a non-positive price, which would corrupt the NAV\\ncalculation.",
          "name": "InvalidOraclePrice",
          "value": 9
        }
      ]
    }
