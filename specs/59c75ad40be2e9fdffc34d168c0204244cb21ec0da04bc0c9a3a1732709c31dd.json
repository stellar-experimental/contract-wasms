  {
    "function_v0": {
      "doc": "Initializes the SAC admin yield token contract.\\n\\n# Arguments\\n* `sac_token` - Address of the SAC token contract this contract administers\\n* `admin` - Top-level authority address\\n* `minter` - Address that can mint/burn tokens and set rate\\n* `yield_recipient_manager` - Address that can set the yield recipient\\n* `yield_recipient` - Address that receives claimed yield (passive \\xe2\\x80\\x94 `claim_yield` is gated by `yield_recipient_manager`)\\n* `forced_transfer_manager` - Address that can authorize accounts and transfer tokens\\n* `block_operator` - Initial address with block permission; added to the block-operator set.\\nMore addresses can be granted via `add_block_operator`.\\n* `unblock_operator` - Initial address with unblock permission; added to the unblock-operator set.\\nMore addresses can be granted via `add_unblock_operator`. May equal `block_operator`.\\n* `pauser` - Initial address with pause permission; added to the pauser set.\\nMore addresses can be granted via `add_pauser`.",
      "name": "__constructor",
      "inputs": [
        {
          "doc": "",
          "name": "sac_token",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "admin",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "minter",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "yield_recipient_manager",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "yield_recipient",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "forced_transfer_manager",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "block_operator",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "unblock_operator",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "pauser",
          "type_": "address"
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": "void",
            "error_type": {
              "udt": {
                "name": "MinterGatewayError"
              }
            }
          }
        }
      ]
    }
  },
