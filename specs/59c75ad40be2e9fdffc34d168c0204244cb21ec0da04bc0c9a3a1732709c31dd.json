    "function_v0": {
      "doc": "Forces a transfer of SAC tokens between accounts (clawback + mint).\\nForced transfer manager only. Does not require source authorization.\\nAccumulators are not touched \\xe2\\x80\\x94 supply is unchanged.\\n\\nNot pause-gated: a compliance primitive must stay executable during a\\npause, alongside `block_user` / `unblock_user`.",
      "name": "force_transfer",
      "inputs": [
        {
          "doc": "",
          "name": "caller",
          "type_": "address"
        },
