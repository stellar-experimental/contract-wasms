  {
    "function_v0": {
      "doc": "Returns whether the given account is blocked.\\nMatches `stellar_tokens::fungible::blocklist::FungibleBlockList::blocked` \\xe2\\x80\\x94\\n`true` means the account is blocked (SAC-unauthorized). Untouched\\naccounts return `true` because the SAC issuer uses AUTH_REQUIRED.\\n\\nThe SAC's `authorized` host function traps (not returns `false`) when\\nthe account has no classic trustline for the asset \\xe2\\x80\\x94 so a naive\\n`!authorized(account)` would make `blocked()` unusable for onboarding\\npre-flight checks. We catch that trap via `try_authorized` and treat\\nany non-success outcome as \"blocked\": without a trustline there is no\\nauthorization state, so denying is the safe and truthful answer.",
      "name": "blocked",
      "inputs": [
        {
          "doc": "",
          "name": "account",
          "type_": "address"
        }
      ],
      "outputs": [
        "bool"
      ]
    }
  },
  {
    "function_v0": {
      "doc": "Unpauses the contract, resuming all blocked operations.\\nPauser only.",
