    "function_v0": {
      "doc": "Process accumulated AQUA: swap into ecosystem tokens via Aquarius AMM,\\nthen distribute to Revenue Vault.\\n\\nv1.1.0: Processes AQUA already held BY this contract (deposited by admin\\nvia simple Stellar payment). No transfer from caller needed.\\n\\n- `caller`: Admin or authorized bot\\n- `swap_chains`: One per reward token \\xe2\\x80\\x94 Vec of (pool_tokens, pool_hash, token_out)\\nobtained from the Aquarius Find Path API\\n- `out_mins`: Minimum output per swap (slippage protection)\\n\\nSwap chains are built off-chain via:\\nPOST https://amm-api.aqua.network/api/external/v1/find-path/",
      "name": "process_revenue",
      "inputs": [
        {
          "doc": "",
          "name": "caller",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "swap_chains",
          "type_": {
            "vec": {
              "element_type": {
                "vec": {
                  "element_type": {
                    "tuple": {
                      "value_types": [
                        {
                          "vec": {
                            "element_type": "address"
                          }
                        },
                        {
                          "bytes_n": {
                            "n": 32
                          }
                        },
                        "address"
                      ]
                    }
                  }
                }
              }
            }
          }
        },
        {
          "doc": "",
          "name": "out_mins",
          "type_": {
            "vec": {
              "element_type": "u128"
            }
          }
        }
      ],
      "outputs": []
    }
