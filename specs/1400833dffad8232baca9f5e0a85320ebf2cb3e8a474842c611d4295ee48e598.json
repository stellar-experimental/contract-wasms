      "fields": [
        {
          "doc": "Minimum amount of token0 to use in mint",
          "name": "amount0_min",
          "type_": "u128"
        },
        {
          "doc": "Minimum amount of token1 to use in mint",
          "name": "amount1_min",
          "type_": "u128"
        },
        {
          "doc": "Amount of token_in to zap",
          "name": "amount_in",
          "type_": "i128"
        },
        {
          "doc": "Transaction deadline (ledger timestamp)",
          "name": "deadline",
          "type_": "u64"
        },
        {
          "doc": "Fee tiers for each hop to token0 (len = path_to_token0.len() - 1)",
          "name": "fees_to_token0",
          "type_": {
            "vec": {
              "element_type": "u32"
            }
          }
        },
        {
          "doc": "Fee tiers for each hop to token1 (len = path_to_token1.len() - 1)",
          "name": "fees_to_token1",
          "type_": {
            "vec": {
              "element_type": "u32"
            }
          }
        },
        {
          "doc": "Minimum liquidity to receive",
          "name": "min_liquidity",
          "type_": "u128"
        },
        {
          "doc": "Full path from token_in to token0: [token_in, intermediate..., token0]\\nEmpty if token_in == token0 (no swap needed for token0 side)",
          "name": "path_to_token0",
          "type_": {
            "vec": {
              "element_type": "address"
            }
          }
        },
        {
          "doc": "Full path from token_in to token1: [token_in, intermediate..., token1]\\nEmpty if token_in == token1 (no swap needed for token1 side)",
          "name": "path_to_token1",
          "type_": {
            "vec": {
              "element_type": "address"
            }
          }
        },
        {
          "doc": "Target liquidity pool address",
          "name": "pool",
          "type_": "address"
        },
        {
          "doc": "Address to receive the NFT position",
          "name": "recipient",
          "type_": "address"
        },
        {
          "doc": "Address providing the input tokens (must authorize)",
          "name": "sender",
          "type_": "address"
        },
        {
          "doc": "Optional client-computed swap amount hint\\nIf None: contract calculates optimal split on-chain\\nIf Some: contract uses this value (still validates with slippage)",
          "name": "swap_amount_hint",
          "type_": {
            "option": {
              "value_type": "i128"
            }
          }
        },
        {
          "doc": "Minimum output from swap to token0 (per-swap slippage protection)\\nSet to 0 to skip this check",
          "name": "swap_to_token0_min_out",
          "type_": "i128"
        },
        {
          "doc": "Minimum output from swap to token1 (per-swap slippage protection)\\nSet to 0 to skip this check",
          "name": "swap_to_token1_min_out",
          "type_": "i128"
        },
        {
          "doc": "Lower tick boundary for position",
          "name": "tick_lower",
          "type_": "i32"
        },
        {
          "doc": "Upper tick boundary for position",
          "name": "tick_upper",
          "type_": "i32"
        },
        {
          "doc": "Input token address (can be ANY token)",
          "name": "token_in",
          "type_": "address"
        }
      ]
    }
