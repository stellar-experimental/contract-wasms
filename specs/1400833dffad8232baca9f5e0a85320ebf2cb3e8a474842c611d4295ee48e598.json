  {
    "function_v0": {
      "doc": "Initialize the Zap Router\\n\\n# Arguments\\n* `factory` - DEX factory address (for pool lookups and token ordering)\\n* `xlm` - Native XLM token address (for gas refunds)\\n* `position_manager` - NonFungiblePositionManager address (for NFT minting)\\n* `swap_router` - SwapRouter address (for ALL swaps - single and multi-hop)\\n\\n# Note on Router Architecture\\nZap uses the existing swap-router for ALL swap operations.\\nThis means:\\n- swap-router remains the authorized router (no changes needed)\\n- Zap does NOT need to be authorized as a router\\n- No duplication of swap/multi-hop logic",
      "name": "init",
      "inputs": [
        {
          "doc": "",
          "name": "factory",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "xlm",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "position_manager",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "swap_router",
          "type_": "address"
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": {
              "tuple": {
                "value_types": []
              }
            },
            "error_type": {
              "udt": {
                "name": "ZapError"
              }
            }
          }
        }
      ]
    }
  },
  {
    "function_v0": {
      "doc": "Zap in with a single token to receive an NFT LP position\\n\\n# Flow\\n1. Transfer token_in from sender to zap contract\\n2. Calculate optimal split (or use hint)\\n3. Execute swaps to acquire pool tokens\\n4. Mint NFT position via position manager\\n5. Refund any dust to sender\\n\\n# Returns\\n* `token_id` - NFT position ID\\n* `liquidity` - Liquidity minted\\n* `amount0` - Amount of token0 used\\n* `amount1` - Amount of token1 used",
      "name": "zap_in",
      "inputs": [
        {
          "doc": "",
          "name": "params",
          "type_": {
            "udt": {
              "name": "ZapInParams"
            }
          }
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": {
              "udt": {
                "name": "ZapInResult"
              }
            },
            "error_type": {
              "udt": {
                "name": "ZapError"
              }
            }
          }
        }
      ]
    }
  },
  {
    "function_v0": {
      "doc": "Zap out from an NFT LP position to a single token\\n\\n# Flow\\n1. Decrease liquidity on position\\n2. Collect tokens + accrued fees\\n3. Swap all to desired output token\\n4. Transfer to recipient\\n\\n# Note\\nNFT burning is NOT supported via zap_out. To burn an NFT after a full exit,\\ncall `position_manager.burn(token_id)` directly.\\n\\n# Returns\\n* `amount_out` - Total amount of token_out received",
      "name": "zap_out",
      "inputs": [
        {
          "doc": "",
          "name": "params",
          "type_": {
            "udt": {
              "name": "ZapOutParams"
            }
          }
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": {
              "udt": {
                "name": "ZapOutResult"
              }
            },
            "error_type": {
              "udt": {
                "name": "ZapError"
              }
            }
          }
        }
      ]
    }
  },
