  {
    "function_v0": {
      "doc": "Pause all payment triggers and new subscription creation. Owner only.\\nThe `Paused` flag lives in persistent storage and its TTL is bumped\\non every toggle so a prolonged pause window cannot silently expire.",
      "name": "pause",
      "inputs": [],
      "outputs": []
    }
  },
  {
    "function_v0": {
      "doc": "Cancel a subscription. Only the subscriber can cancel.",
      "name": "cancel",
      "inputs": [
        {
          "doc": "",
          "name": "id",
          "type_": "u64"
        }
      ],
      "outputs": []
    }
  },
  {
    "function_v0": {
      "doc": "Create a new recurring subscription.\\n\\n`token` MUST be a SEP-41-compliant contract address. Passing a non-compliant\\naddress will not fail at creation time \\xe2\\x80\\x94 it will cause `trigger` to panic when\\n`transfer_from` is invoked. The caller is responsible for verifying the token.\\n\\n`interval` is in seconds and must be in `1..=MAX_INTERVAL` (10 years).\\n\\nThe subscriber must call `token.approve(this_contract_address, amount)` before\\neach payment cycle, or once with a sufficiently large allowance.\\nAfter calling `cancel`, the subscriber MUST also call\\n`token.approve(this_contract_address, 0)` to revoke the allowance.",
      "name": "create",
      "inputs": [
        {
          "doc": "",
          "name": "subscriber",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "token",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "recipient",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "amount",
          "type_": "i128"
        },
        {
          "doc": "",
          "name": "interval",
          "type_": "u64"
        }
      ],
      "outputs": [
        "u64"
      ]
    }
  },
  {
    "function_v0": {
      "doc": "Trigger the next payment for subscription `id`.\\n\\n**Permissionless**: anyone (keeper, bot, recipient, subscriber) may call\\nthis once the payment is due. Safety derives from:\\n- the pre-approved `allowance` (subscriber's consent to pull funds), and\\n- the `recipient` being fixed at creation (no third party can redirect).\\n\\nThe token is pulled from the subscriber via `transfer_from`, so the\\nsubscriber must have granted a sufficient allowance to this contract\\naddress beforehand.",
      "name": "trigger",
      "inputs": [
        {
          "doc": "",
          "name": "id",
          "type_": "u64"
        }
      ],
      "outputs": []
    }
  },
  {
    "function_v0": {
      "doc": "Resume normal operation. Owner only.",
      "name": "unpause",
      "inputs": [],
      "outputs": []
    }
  },
  {
    "function_v0": {
      "doc": "Hot-swap the contract WASM. Owner only. Use to patch bugs without\\ndraining user allowances; always couple with `pause` + off-chain review\\nof `new_wasm_hash` before calling.",
      "name": "upgrade",
      "inputs": [
        {
          "doc": "",
          "name": "new_wasm_hash",
          "type_": {
            "bytes_n": {
              "n": 32
            }
          }
        }
      ],
      "outputs": []
    }
  },
  {
    "function_v0": {
      "doc": "Batch-catch up to `count` consecutive due cycles in a single tx.\\n\\nThe contract processes `min(count, due_cycles)` where\\n`due_cycles = (now - next_payment) / interval + 1`, advances\\n`next_payment` by the corresponding amount of intervals (no drift),\\nand pulls `cycles_processed * amount` from the subscriber in a single\\n`transfer_from`. Useful for keepers/recipients catching up after a\\npause window or downtime.\\n\\nLike `trigger`, this is permissionless \\xe2\\x80\\x94 the subscriber's allowance\\n(which must cover the total amount) is the consent.",
      "name": "trigger_n",
      "inputs": [
        {
          "doc": "",
          "name": "id",
          "type_": "u64"
        },
        {
          "doc": "",
          "name": "count",
          "type_": "u32"
        }
      ],
      "outputs": []
    }
  },
  {
    "function_v0": {
      "doc": "Atomic constructor \\xe2\\x80\\x94 invoked exactly once by the Soroban runtime\\nat contract deployment. This eliminates the front-running window that a\\ntwo-step `deploy` + `initialize` flow would expose.",
      "name": "__constructor",
      "inputs": [
        {
          "doc": "",
          "name": "owner",
          "type_": "address"
        }
      ],
      "outputs": []
    }
  },
  {
    "function_v0": {
      "doc": "Atomically transfer ownership. The transaction must carry signatures\\nfrom BOTH the current owner and the new owner \\xe2\\x80\\x94 this rules out\\ntransferring to a wrong or unresponsive address (the wrong key cannot\\nsign) without requiring a separate acceptance step.",
      "name": "transfer_ownership",
      "inputs": [
        {
          "doc": "",
          "name": "new_owner",
          "type_": "address"
        }
      ],
      "outputs": []
    }
