    "function_v0": {
      "doc": "Custom authorization function invoked by the Soroban runtime.\\n\\nThis function implements the account's authorization logic with optimizations for Stellar costs:\\n1. Verifies that all provided signatures are cryptographically valid\\n2. Checks that at least one authorized signer has approved each operation\\n3. Ensures signers have the required permissions for the requested operations\\n\\n\\n# Arguments\\n* `env` - The contract environment\\n* `signature_payload` - Hash of the data that was signed\\n* `auth_payloads` - Map of signer keys to their signature proofs\\n* `auth_contexts` - List of operations being authorized\\n\\n# Returns\\n* `Ok(())` if authorization succeeds\\n* `Err(Error)` if authorization fails for any reason",
      "name": "__check_auth",
      "inputs": [
        {
          "doc": "",
          "name": "signature_payload",
          "type_": {
            "bytes_n": {
              "n": 32
            }
          }
        },
        {
          "doc": "",
          "name": "auth_payloads",
          "type_": {
            "udt": {
              "name": "SignatureProofs"
            }
          }
        },
        {
          "doc": "",
          "name": "auth_contexts",
          "type_": {
            "vec": {
              "element_type": {
                "udt": {
                  "name": "Context"
                }
              }
            }
          }
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": {
              "tuple": {
                "value_types": []
              }
            },
            "error_type": "error"
          }
        }
      ]
    }
