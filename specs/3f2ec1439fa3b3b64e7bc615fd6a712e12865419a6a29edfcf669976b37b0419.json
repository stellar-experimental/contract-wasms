  {
    "udt_struct_v0": {
      "doc": "One parallel branch of the split. `parts` is the integer share of the\\ntotal input (same model as the router's buildSorobanDistribution:\\nstrand_in = floor(amount_in * parts / total_parts), last strand takes\\nthe remainder). `hops` runs sequentially (multi-hop) within the branch.",
      "lib": "",
      "name": "Strand",
      "fields": [
        {
          "doc": "",
          "name": "hops",
          "type_": {
            "vec": {
              "element_type": {
                "udt": {
                  "name": "Hop"
                }
              }
            }
          }
        },
        {
          "doc": "",
          "name": "parts",
          "type_": "u32"
        }
      ]
    }
  },
  {
    "function_v0": {
      "doc": "S4 \\xe2\\x80\\x94 SPLITTER. Execute a full VFalgo plan in ONE call: parallel\\nstrands (split), each with sequential hops (multi-hop), across any\\nmix of Soroswap / Aquarius / Phoenix. Slippage is enforced on the\\nSUM of all strand outputs (atomic across the whole plan).\\n\\nstrand_in = floor(amount_in * parts / total_parts); the last\\nstrand takes the remainder so the split sums to amount_in exactly.\\nWithin a strand, each hop consumes the previous hop's output.",
      "name": "swap",
      "inputs": [
        {
          "doc": "",
          "name": "user",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "token_in",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "token_out",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "amount_in",
          "type_": "i128"
        },
        {
          "doc": "",
          "name": "amount_out_min",
          "type_": "i128"
        },
        {
          "doc": "",
          "name": "deadline",
          "type_": "u64"
        },
        {
          "doc": "",
          "name": "plan",
          "type_": {
            "vec": {
              "element_type": {
                "udt": {
                  "name": "Strand"
                }
              }
            }
          }
        }
      ],
      "outputs": [
        "i128"
      ]
    }
  },
  {
    "function_v0": {
      "doc": "One Aquarius swap through the router's `swap_chained`.\\n\\n`pool_tokens`  \\xe2\\x80\\x94 the pool's ordered token vector (canonical, by\\ncontract-id). For USDC/AQUA: [AQUA_SAC, USDC_SAC].\\n`pool_index`   \\xe2\\x80\\x94 the pool hash (BytesN<32>) from get_pools.\\n`pool`         \\xe2\\x80\\x94 the pool contract address (the router pulls\\ntoken_in into it; used for the auth subtree).\\n`token_in/out` \\xe2\\x80\\x94 SAC contract ids.\\n\\nswap_chained(user, swaps_chain, token_in, in_amount, out_min):\\nswaps_chain = [ (pool_tokens, pool_index, token_out) ]   (single hop)\\n\\nReturns the amount of token_out delivered (u128 -> i128).",
