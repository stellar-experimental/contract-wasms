      "inputs": [
        {
          "doc": "",
          "name": "account",
          "type_": "address"
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": {
              "udt": {
                "name": "NAVResult"
              }
            },
            "error_type": {
              "udt": {
                "name": "PositionError"
              }
            }
          }
        }
      ]
    }
