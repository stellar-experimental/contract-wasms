  {
    "function_v0": {
      "doc": "SPIKE \\xe2\\x80\\x94 shared-VK BATCHED Groth16 verification. All Veil proofs reuse one VK, so the\\nalpha/gamma/delta terms collapse into G1 MSMs and N proofs verify in ONE pairing_check of\\nN+3 pairs (vs 4N naive). r_i are Fiat-Shamir scalars from a keccak transcript over every\\nproof + public input, so a relayer cannot grind a malicious batch. Verify-only (no tree/\\nnullifier settle) \\xe2\\x80\\x94 measures the on-chain cost curve for the aggregation design.",
      "name": "batch_verify",
      "inputs": [
        {
          "doc": "",
          "name": "a",
          "type_": {
            "vec": {
              "element_type": {
                "bytes_n": {
