  {
    "udt_struct_v0": {
      "doc": "A dynamic state read the contract performs right before invoking a step.\\n\\nNeeded for DEXes whose swap args include state that changes ledger-by-ledger\\n(e.g. Sushi v3 `OracleHints`). Fetching off-chain and passing through the tx\\nleaves a race window; another swap hitting the pool in the same ledger\\ninvalidates the value and the inner tx reverts. When `prefetch` is `Some(pf)`\\nthe contract calls the view, splices the returned `Val` into `args[inject_at]`\\nand into any matching `sub_auth` entry so the authorize entry stays\\nbyte-for-byte equal to the actual call.",
      "lib": "",
      "name": "Prefetch",
      "fields": [
        {
          "doc": "",
          "name": "args",
          "type_": {
            "vec": {
              "element_type": "val"
            }
          }
        },
        {
          "doc": "",
          "name": "fn_name",
          "type_": "symbol"
        },
        {
          "doc": "",
          "name": "inject_at",
          "type_": "u32"
        },
        {
          "doc": "",
          "name": "target",
          "type_": "address"
        }
      ]
    }
  },
  {
    "udt_struct_v0": {
      "doc": "A single opaque cross-contract call. The contract has no DEX-specific\\nknowledge \\xe2\\x80\\x94 the off-chain route builder produces `args` + `sub_auth` for\\neach venue's call pattern (Aquarius direct pool, Sushi v3 oracle hints,\\nComet weighted pool, etc.).",
      "lib": "",
      "name": "SwapStep",
      "fields": [
        {
          "doc": "",
          "name": "args",
          "type_": {
            "vec": {
              "element_type": "val"
            }
          }
        },
        {
          "doc": "",
          "name": "fn_name",
          "type_": "symbol"
        },
        {
          "doc": "",
          "name": "prefetch",
          "type_": {
            "option": {
              "value_type": {
                "udt": {
                  "name": "Prefetch"
                }
              }
            }
          }
        },
        {
          "doc": "",
          "name": "sub_auth",
          "type_": {
            "vec": {
              "element_type": {
                "udt": {
                  "name": "InvokerContractAuthEntry"
                }
              }
            }
          }
        },
        {
          "doc": "",
          "name": "target",
          "type_": "address"
        }
      ]
    }
  },
