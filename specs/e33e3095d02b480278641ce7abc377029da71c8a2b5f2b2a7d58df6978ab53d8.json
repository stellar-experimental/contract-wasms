  {
    "function_v0": {
      "doc": "Aggregated, atomic swap with a platform fee skim.\\n\\n- `user`: the trader; the transaction source account (single signature).\\n- `asset_in` / `total_amount_in`: pulled from `user` into the contract.\\n- `asset_out` / `min_total_out`: revert unless the contract nets at least\\n`min_total_out` of `asset_out` across all routes.\\n- `fee_route`: swaps the skimmed fee (in `asset_in`) into the fee asset\\n(XLM). Empty when `asset_in` already is the fee asset.\\n- `fee_min_out`: lax floor for the fee conversion (should never revert).\\n- `routes`: the split \\xe2\\x80\\x94 each `Route.amount_in` of `asset_in` through its\\nown `path`. `sum(amount_in)` must equal `total_amount_in - fee`.\\n\\n`fee_ppm` and `fee_to` are read from contract storage, never the caller.",
      "name": "swap_split",
      "inputs": [
        {
          "doc": "",
          "name": "user",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "asset_in",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "total_amount_in",
          "type_": "i128"
        },
        {
          "doc": "",
          "name": "asset_out",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "min_total_out",
          "type_": "i128"
        },
        {
          "doc": "",
          "name": "fee_route",
          "type_": {
            "vec": {
              "element_type": {
                "udt": {
                  "name": "SwapStep"
                }
              }
            }
          }
        },
        {
          "doc": "",
          "name": "fee_min_out",
          "type_": "i128"
        },
        {
          "doc": "",
          "name": "routes",
          "type_": {
            "vec": {
              "element_type": {
                "udt": {
                  "name": "Route"
                }
              }
            }
          }
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": "i128",
            "error_type": {
              "udt": {
                "name": "SwapError"
              }
            }
          }
        }
      ]
    }
  },
