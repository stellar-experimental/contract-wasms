    "udt_enum_v0": {
      "doc": "Auction phases:\\n1. COMMIT: Bidders submit hash(bid + salt) \\xe2\\x80\\x94 bids hidden\\n2. REVEAL: Bidders reveal their bid + salt \\xe2\\x80\\x94 contract verifies\\n3. SETTLE: Winner pays, domain transfers",
      "lib": "",
      "name": "AuctionPhase",
      "cases": [
        {
          "doc": "",
          "name": "Commit",
          "value": 0
        },
        {
          "doc": "",
          "name": "Reveal",
          "value": 1
        },
        {
          "doc": "",
          "name": "Settled",
          "value": 2
        },
        {
          "doc": "",
          "name": "Cancelled",
          "value": 3
        }
      ]
    }
  },
