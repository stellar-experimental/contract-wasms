  {
    "function_v0": {
      "doc": "Claim an invite during the \"register <code>\" DM flow.\\nCalled immediately after register() for users who aren't in the group yet\\n(so they don't have a SenderKey). TEE signature is the only auth.\\n\\nFor users already in the group, \"claim <code>\" goes through\\nexecute_signal_instruction with full SenderKey verification instead.\\nclaim_invite now takes a 32-byte invite_hash (SHA256(pepper || code))\\ninstead of a plaintext code. The relay computes the hash using its\\nTEE-held pepper and passes it here.",
      "name": "claim_invite",
      "inputs": [
        {
          "doc": "",
          "name": "signal_username",
          "type_": "string"
        },
        {
          "doc": "",
          "name": "claimer_identity",
          "type_": {
            "bytes_n": {
              "n": 32
            }
          }
        },
        {
          "doc": "",
          "name": "invite_hash",
          "type_": {
            "bytes_n": {
              "n": 32
            }
          }
