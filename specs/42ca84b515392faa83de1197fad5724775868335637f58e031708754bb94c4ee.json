  {
    "function_v0": {
      "doc": "Aggregated, atomic swap with a platform-fee skim.\\n\\n- `user`: the trader and transaction source (single signature).\\n- `asset_in` / `total_amount_in`: pulled from `user` into the contract.\\n- `asset_out` / `min_total_out`: revert unless the contract nets at least\\n`min_total_out` of `asset_out` across all routes.\\n- `routes`: the split \\xe2\\x80\\x94 each `Route.amount_in` of `asset_in` through its\\nown `path`. `sum(amount_in)` must equal `total_amount_in - fee`.\\n\\nThe `fee_ppm` skim is retained in the contract **in the input asset** and\\nswept/converted to the fee asset later by the owner (deferred \\xe2\\x80\\x94 avoids a\\nsecond in-band swap in every user transaction). `fee_ppm`/`fee_to` are\\nread from storage, never the caller.",
      "name": "swap_split",
      "inputs": [
        {
          "doc": "",
          "name": "user",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "asset_in",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "total_amount_in",
          "type_": "i128"
        },
        {
          "doc": "",
          "name": "asset_out",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "min_total_out",
          "type_": "i128"
        },
        {
          "doc": "",
          "name": "routes",
          "type_": {
            "vec": {
              "element_type": {
                "udt": {
                  "name": "Route"
                }
              }
            }
          }
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": "i128",
            "error_type": {
              "udt": {
                "name": "SwapError"
              }
            }
          }
        }
      ]
    }
  },
