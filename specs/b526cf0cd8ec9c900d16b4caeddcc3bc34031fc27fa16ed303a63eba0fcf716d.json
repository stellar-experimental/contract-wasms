    "function_v0": {
      "doc": "Atomically swap the messenger adapter and snapshot its prior per-chain\\ntrusted remotes for the migration grace period.\\n\\nEach messenger encodes the source sender address differently; in-flight\\ninbound messages from the previous messenger only validate against the\\nremote captured at migration time. Chains not in `chains` keep their\\nold-encoding remote under the new messenger (effectively disabled)\\nuntil a follow-up `migrate_messenger` adds them.\\n\\nRequires OPERATOR role.",
      "name": "migrate_messenger",
      "inputs": [
        {
          "doc": "",
          "name": "messenger",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "chains",
          "type_": {
            "vec": {
              "element_type": "string"
            }
          }
        },
        {
          "doc": "",
          "name": "new_remotes",
          "type_": {
            "vec": {
              "element_type": "string"
            }
          }
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": "void",
            "error_type": {
              "udt": {
                "name": "BridgeError"
              }
            }
          }
        }
      ]
    }
  },
