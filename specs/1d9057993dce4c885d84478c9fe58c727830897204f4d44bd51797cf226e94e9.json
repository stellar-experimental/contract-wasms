  {
    "udt_union_v0": {
      "doc": "Storage keys for the bridge\\nNote: Authorization is handled by AccessControl crate (Owner, Admin, SystemWallet roles)\\n\\nStorage Type Strategy:\\n- Instance Storage: CurrentChainId, ProposedOwner\\n- Configuration data set during initialization\\n- Survives upgrades but tied to instance\\n\\n- Persistent Storage: TransactionIds, LockedBalances\\n- TransactionIds: CRITICAL for preventing replay attacks\\n* MUST use persistent storage in PRODUCTION (uncomment persistent, comment temporary)\\n* Can use temporary storage in DEVELOPMENT ONLY for lower fees during testing\\n- LockedBalances: Financial state that must be preserved accurately\\n* Uses persistent storage but relies on Protocol 23 automatic restoration\\n* When archived, Stellar SDK's simulateTransaction() auto-restores before execution\\n* Users pay minimal restoration fees (~7 ledgers) only when accessing expired entries\\n* No need to extend TTL on every lock operation (saves gas for users)\\n- Each entry has independent TTL management\\n- Survives contract upgrades with data integ",
      "lib": "",
      "name": "DataKey",
      "cases": [
        {
          "void_v0": {
            "doc": "",
            "name": "CurrentChainId"
          }
        },
        {
          "void_v0": {
            "doc": "",
            "name": "ProposedOwner"
          }
        },
        {
          "tuple_v0": {
            "doc": "",
            "name": "LockedBalances",
            "type_": [
              "address"
            ]
          }
        },
        {
          "tuple_v0": {
            "doc": "",
            "name": "TransactionIds",
            "type_": [
              "i128"
            ]
          }
        }
      ]
    }
  },
