    "function_v0": {
      "doc": "Deposit assets into a FIXED denomination privacy pool\\nThe amount is determined by the denomination pool selected\\nThis makes ALL deposits in the same pool identical - hiding amounts from Lobstr UI\\n\\nParameters:\\n- denomination: Which fixed amount pool (1, 5, 10, or 100 XLM)\\n- caller: Who is depositing\\n- token: Token contract address\\n- commitment: Hash commitment (hiding the secret and recipient)\\n\\nExample: Everyone depositing to OneXLM pool deposits exactly 1 XLM",
      "name": "deposit",
      "inputs": [
        {
          "doc": "",
          "name": "denomination",
          "type_": {
            "udt": {
              "name": "Denomination"
            }
          }
        },
        {
          "doc": "",
          "name": "caller",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "token",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "commitment",
          "type_": {
            "bytes_n": {
              "n": 32
            }
          }
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": "u32",
            "error_type": {
              "udt": {
                "name": "ContractError"
              }
            }
          }
        }
      ]
    }
  },
  {
    "function_v0": {
      "doc": "Withdraw assets from a FIXED denomination privacy pool\\nUses ZK proof to prove ownership without revealing which deposit is being spent\\nThe amount is determined by the denomination pool\\n\\nParameters:\\n- denomination: Which fixed amount pool to withdraw from\\n- proof: ZK-SNARK proof (would use BN254 pairing check in production)\\n- nullifier: Prevents double-spending (hash of secret)\\n- recipient: Who receives the funds\\n- token: Which token to withdraw",
      "name": "withdraw",
      "inputs": [
        {
          "doc": "",
          "name": "denomination",
          "type_": {
            "udt": {
              "name": "Denomination"
            }
