  {
    "udt_union_v0": {
      "doc": "Shared storage keys for token utilities and asset configuration.\\n\\nNOTE:\\n- `AllowanceExpiration` is stored as a ledger offset, not an absolute ledger.\\n- Spend limits are stored in instance storage because they are contract-wide config.\\n- Supported assets are stored in persistent storage as a set-like `Map<Address, ()>`.",
      "lib": "",
      "name": "DataKey",
      "cases": [
        {
          "void_v0": {
            "doc": "Relative ledger offset used when creating token approvals.",
            "name": "AllowanceExpiration"
          }
        },
        {
          "void_v0": {
            "doc": "Default spend limit used when an asset-specific limit is not set.",
            "name": "DefaultSpendLimit"
          }
        },
        {
          "tuple_v0": {
            "doc": "Per-asset spend limit override.",
            "name": "SpendLimit",
            "type_": [
              "address"
            ]
          }
        },
        {
          "void_v0": {
            "doc": "Set of assets supported by the caller contract.",
            "name": "SupportedAssets"
          }
        }
      ]
    }
  }
