  {
    "function_v0": {
      "doc": "Authorize a user with a Gmail ZK proof.\\n\\nThis is the main entry point for proving Gmail ownership.\\nThe user provides a Groth16 proof that demonstrates:\\n1. They have a valid server attestation (semi-trusted mode)\\n2. The attestation is recent (within 24 hours)\\n3. The commitment correctly hides their gmail hash\\n4. The nullifier is correctly derived\\n\\n# Arguments\\n* `proof_a` - G1 point A from Groth16 proof\\n* `proof_b` - G2 point B from Groth16 proof\\n* `proof_c` - G1 point C from Groth16 proof\\n* `request` - Authorization request with commitment and nullifier\\n\\n# Returns\\n* `AuthorizationResult` on success\\n\\n# Errors\\n* `NotInitialized` - Contract not initialized\\n* `NullifierAlreadyUsed` - Replay attack prevented\\n* `InvalidProof` - Groth16 verification failed",
      "name": "authorize",
      "inputs": [
        {
          "doc": "",
          "name": "proof_a",
          "type_": {
            "bytes_n": {
              "n": 64
            }
          }
        },
        {
          "doc": "",
          "name": "proof_b",
          "type_": {
            "bytes_n": {
              "n": 128
            }
          }
        },
        {
          "doc": "",
          "name": "proof_c",
          "type_": {
            "bytes_n": {
              "n": 64
            }
          }
        },
        {
          "doc": "",
          "name": "request",
          "type_": {
            "udt": {
              "name": "AuthorizationRequest"
            }
          }
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": {
              "udt": {
                "name": "AuthorizationResult"
              }
            },
            "error_type": {
              "udt": {
                "name": "GmailAuthError"
              }
            }
          }
        }
      ]
    }
  },
  {
    "udt_struct_v0": {
      "doc": "Authorization request containing proof and public outputs.\\nFields MUST be in alphabetical order for Soroban struct encoding.",
      "lib": "",
