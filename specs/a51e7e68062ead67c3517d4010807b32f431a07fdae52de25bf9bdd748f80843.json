    "function_v0": {
      "doc": "Check if a commitment is authorized (exists in merkle tree).\\n\\nThis is used by dApps to verify a user's Gmail authorization status.\\n\\n# Arguments\\n* `commitment` - The commitment to check\\n* `merkle_proof` - Merkle proof of membership\\n* `leaf_index` - Index of the leaf in the tree\\n\\n# Returns\\ntrue if the commitment is in the authorized set",
      "name": "is_authorized",
      "inputs": [
        {
          "doc": "",
          "name": "commitment",
          "type_": "u256"
        },
        {
          "doc": "",
