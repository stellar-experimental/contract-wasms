  {
    "function_v0": {
      "doc": "Closes the caller's open position and settles PnL against the LP pool.\\n\\nPnL is computed on-chain from stored entry data and the caller-provided\\nclose price:\\n- long:  pnl = (close_price - entry_price) * xlm_amount / SCALE\\n- short: pnl = (entry_price - close_price) * xlm_amount / SCALE\\n\\n- pnl > 0: pool pays the winner \\xe2\\x80\\x94 PoolBalance -= pnl, UserMargin += collateral + pnl\\n- pnl < 0: pool gains from the loser \\xe2\\x80\\x94 PoolBalance += |pnl|, UserMargin += collateral - |pnl|\\n- pnl = 0: UserMargin += collateral (no pool impact)\\n\\nReturns `InsufficientPool` if the pool cannot cover a winning payout.",
      "name": "close_position",
      "inputs": [
        {
          "doc": "",
          "name": "user",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "collateral_token",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "close_price",
          "type_": "i128"
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": {
              "udt": {
                "name": "Position"
              }
            },
            "error_type": "error"
          }
        }
      ]
    }
  },
