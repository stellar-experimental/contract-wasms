  {
    "function_v0": {
      "doc": "Execute an arbitrage route atomically.\\n\\n- `caller`: submitter account (must be in the allowlist). Pays the tx inclusion fee.\\n- `trader`: capital provider. Seeds the route with `amount_in` of `asset_in`\\nand receives the final `base_asset` balance at the end.\\n- `asset_in` / `amount_in`: tokens pulled from trader into the contract before step 0.\\n- `base_asset`: token measured at the end for the profit check.\\n- `min_final_balance`: revert if the contract's `base_asset` balance is below this\\nafter the last step runs. This is the on-chain backstop against stale quotes.\\n- `route`: ordered list of opaque sub-calls. The contract invokes each as-is.\\n\\nReturns the final `base_asset` balance returned to the trader.",
      "name": "execute",
      "inputs": [
        {
          "doc": "",
          "name": "caller",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "trader",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "asset_in",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "amount_in",
          "type_": "i128"
        },
        {
          "doc": "",
          "name": "base_asset",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "min_final_balance",
          "type_": "i128"
        },
        {
          "doc": "",
          "name": "route",
          "type_": {
            "vec": {
              "element_type": {
                "udt": {
                  "name": "SwapStep"
                }
              }
            }
          }
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": "i128",
            "error_type": {
              "udt": {
                "name": "ArbError"
              }
            }
          }
        }
      ]
    }
  },
