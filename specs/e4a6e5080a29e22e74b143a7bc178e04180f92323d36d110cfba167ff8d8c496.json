  {
    "function_v0": {
      "doc": "Verify a Groth16 proof and store the tier attestation on-chain.\\n\\nThis performs the full Groth16 pairing check:\\ne(pi_a, pi_b) == e(alpha, beta) * e(vk_x, gamma) * e(pi_c, delta)\\n\\nWhich is equivalent to checking:\\ne(-pi_a, pi_b) * e(alpha, beta) * e(vk_x, gamma) * e(pi_c, delta) == 1\\n\\nWhere vk_x = IC[0] + sum(pub_input[i] * IC[i+1])\\n\\n# Arguments\\n* `farmer` - Address of the farmer (requires auth)\\n* `tier` - Claimed tier (0-3, public input to circuit)\\n* `commitment` - Poseidon commitment (public input to circuit)\\n* `proof` - The Groth16 proof (pi_a, pi_b, pi_c)",
      "name": "verify_and_attest",
      "inputs": [
        {
          "doc": "",
          "name": "farmer",
          "type_": "address"
        },
        {
          "doc": "",
          "name": "tier",
          "type_": "u32"
        },
        {
          "doc": "",
          "name": "commitment",
          "type_": {
            "bytes_n": {
              "n": 32
            }
          }
        },
        {
          "doc": "",
          "name": "proof",
          "type_": {
            "udt": {
              "name": "Groth16Proof"
            }
          }
        }
      ],
      "outputs": [
        {
          "result": {
            "ok_type": "bool",
            "error_type": {
              "udt": {
                "name": "TierVerifierError"
              }
            }
          }
        }
      ]
    }
  }
